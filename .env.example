# Database password (required, must be strong)
DB_PASSWORD=YourStrong!Password123

# Admin Panel Password (required, sets the login password for the 'aykut' account)
ADMIN_PASSWORD=MySecretAdminLogin!

# Gemini API Key (optional depending on usage)
GEMINI_API_KEY=your_gemini_api_key_here

# Settings for JWT (optional, defaults in appsettings might not be secure for prod)
# JWT_SECRET_KEY=at_least_32_chars_long_secret
