@model AykutOnPC.Core.DTOs.PagedResult<AykutOnPC.Core.Entities.ChatLog>
@{
    ViewData["Title"] = "Question Inbox";
    Layout = "_AdminLayout";
    var unreviewedOnly = (bool)(ViewBag.UnreviewedOnly ?? true);
    var unreviewedCount = (int)(ViewBag.UnreviewedCount ?? 0);

    string Truncate(string? s, int n) =>
        string.IsNullOrEmpty(s) ? "—" :
        s.Length <= n ? s : s[..n] + "…";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h1 style="margin: 0;">Question Inbox</h1>
    <small style="color: var(--text-muted);">
        Visitor soruları buradan KB'ye geçer — closed feedback loop.
    </small>
</div>

@if (TempData["InboxSuccess"] is string msgOk)
{
    <div style="background: rgba(34,197,94,0.1); border: 1px solid #22c55e; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
        ✅ @msgOk
    </div>
}
@if (TempData["InboxError"] is string msgErr)
{
    <div style="background: rgba(239,68,68,0.1); border: 1px solid #ef4444; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
        ❌ @msgErr
    </div>
}

<!-- Filter strip -->
<div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem;">
    <a asp-action="Index" asp-route-unreviewedOnly="true"
       style="padding: 0.5rem 1rem; border-radius: 6px;
              background: @(unreviewedOnly ? "var(--primary)" : "rgba(255,255,255,0.05)");
              color: @(unreviewedOnly ? "white" : "var(--text-muted)");
              text-decoration: none;">
        Bekleyen (@unreviewedCount)
    </a>
    <a asp-action="Index" asp-route-unreviewedOnly="false"
       style="padding: 0.5rem 1rem; border-radius: 6px;
              background: @(!unreviewedOnly ? "var(--primary)" : "rgba(255,255,255,0.05)");
              color: @(!unreviewedOnly ? "white" : "var(--text-muted)");
              text-decoration: none;">
        Hepsi
    </a>
</div>

@if (Model.Items.Count == 0)
{
    <div class="card" style="padding: 2rem; text-align: center; color: var(--text-muted);">
        @(unreviewedOnly ? "🎉 Bekleyen soru yok — temizsin." : "Henüz soru yok.")
    </div>
}
else
{
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.1); text-align: left;">
                <th style="padding: 0.75rem;">Durum</th>
                <th style="padding: 0.75rem;">Soru</th>
                <th style="padding: 0.75rem;">Bot Cevabı</th>
                <th style="padding: 0.75rem;">Tarih</th>
                <th style="padding: 0.75rem;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.Items)
            {
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <td style="padding: 0.75rem;">
                        @if (log.IsReviewed)
                        {
                            <span title="Görüldü" style="color: #22c55e;">✓</span>
                        }
                        else
                        {
                            <span title="Bekliyor" style="color: #f59e0b;">●</span>
                        }
                        @if (log.LinkedKnowledgeEntryId.HasValue)
                        {
                            <span title="KB'ye eklendi" style="color: var(--secondary); margin-left: 0.5rem;">
                                <i class="fa-solid fa-brain"></i>
                            </span>
                        }
                    </td>
                    <td style="padding: 0.75rem;">@Truncate(log.UserMessage, 90)</td>
                    <td style="padding: 0.75rem; color: var(--text-muted);">@Truncate(log.BotResponse, 90)</td>
                    <td style="padding: 0.75rem; color: var(--text-muted); white-space: nowrap;">
                        @log.CreatedAtUtc.ToString("dd MMM HH:mm")
                    </td>
                    <td style="padding: 0.75rem;">
                        <a asp-action="Detail" asp-route-id="@log.Id"
                           style="color: var(--secondary); text-decoration: none;">
                            Aç →
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    @if (Model.Total > Model.PageSize)
    {
        var totalPages = (int)Math.Ceiling(Model.Total / (double)Model.PageSize);
        <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem; justify-content: center;">
            @for (var p = 1; p <= totalPages; p++)
            {
                <a asp-action="Index" asp-route-page="@p" asp-route-unreviewedOnly="@unreviewedOnly"
                   style="padding: 0.5rem 0.85rem; border-radius: 6px;
                          background: @(p == Model.Page ? "var(--primary)" : "rgba(255,255,255,0.05)");
                          color: @(p == Model.Page ? "white" : "var(--text-muted)");
                          text-decoration: none;">
                    @p
                </a>
            }
        </div>
    }
}
