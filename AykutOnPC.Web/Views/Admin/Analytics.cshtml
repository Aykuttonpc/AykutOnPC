@{
    ViewData["Title"] = "Visitor Intelligence";
    Layout = "_AdminLayout";
}

<style>
    /* ── Analytics Page Styles ── */
    .analytics-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .analytics-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        background: linear-gradient(135deg, #4ec9b0, #569cd6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .refresh-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        background: rgba(78, 201, 176, 0.1);
        border: 1px solid rgba(78, 201, 176, 0.3);
        border-radius: 8px;
        color: #4ec9b0;
        cursor: pointer;
        font-size: 0.875rem;
        transition: 0.2s;
    }
    .refresh-btn:hover { background: rgba(78, 201, 176, 0.2); }
    .refresh-btn.loading i { animation: spin 1s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* ── Stat Cards ── */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1.25rem;
        margin-bottom: 2rem;
    }
    .stat-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 14px;
        padding: 1.5rem;
        transition: border-color 0.2s, transform 0.2s;
    }
    .stat-card:hover {
        border-color: rgba(78, 201, 176, 0.3);
        transform: translateY(-2px);
    }
    .stat-card .label {
        font-size: 0.75rem;
        color: var(--text-muted, #888);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.5rem;
    }
    .stat-card .value {
        font-size: 2rem;
        font-weight: 700;
        color: #4ec9b0;
        line-height: 1;
    }
    .stat-card .sub {
        font-size: 0.75rem;
        color: var(--text-muted, #888);
        margin-top: 0.4rem;
    }
    .stat-card .icon {
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
        opacity: 0.5;
    }

    /* ── Charts Grid ── */
    .charts-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    @@media (max-width: 900px) { .charts-grid { grid-template-columns: 1fr; } }

    .chart-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 14px;
        padding: 1.5rem;
    }
    .chart-card h3 {
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted, #888);
        margin-bottom: 1.25rem;
    }
    .chart-card canvas { max-height: 200px; }

    /* ── Top Pages Table ── */
    .table-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 14px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .table-card h3 {
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted, #888);
        margin-bottom: 1.25rem;
    }
    .top-pages-list { list-style: none; padding: 0; margin: 0; }
    .top-pages-list li {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.65rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        font-size: 0.9rem;
    }
    .top-pages-list li:last-child { border-bottom: none; }
    .page-rank {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: rgba(78,201,176,0.12);
        color: #4ec9b0;
        font-size: 0.7rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .page-path { flex: 1; color: #ccc; font-family: 'Courier New', monospace; font-size: 0.82rem; }
    .page-bar-wrap { width: 100px; background: rgba(255,255,255,0.06); border-radius: 4px; height: 6px; flex-shrink: 0; }
    .page-bar { height: 6px; border-radius: 4px; background: linear-gradient(90deg, #4ec9b0, #569cd6); }
    .page-count { color: #4ec9b0; font-weight: 600; font-size: 0.85rem; min-width: 40px; text-align: right; }

    /* ── Loading / Error States ── */
    .analytics-skeleton {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 200px;
        color: var(--text-muted, #888);
        gap: 0.75rem;
        font-size: 0.9rem;
    }
    .error-state {
        background: rgba(255, 80, 80, 0.08);
        border: 1px solid rgba(255, 80, 80, 0.2);
        border-radius: 10px;
        padding: 1.25rem;
        color: #ff8080;
        font-size: 0.875rem;
        display: none;
    }
</style>

<div class="analytics-header">
    <div>
        <h1><i class="fa-solid fa-chart-line" style="-webkit-text-fill-color: unset; color: #4ec9b0; margin-right: 0.5rem;"></i>Visitor Intelligence</h1>
        <p style="color: var(--text-muted); font-size:0.85rem; margin-top:0.25rem;">Server-side tracking — no cookies, GDPR compliant</p>
    </div>
    <button class="refresh-btn" id="refreshBtn" onclick="loadAnalytics()">
        <i class="fa-solid fa-arrows-rotate" id="refreshIcon"></i> Refresh
    </button>
</div>

<div class="error-state" id="errorState">
    <i class="fa-solid fa-triangle-exclamation"></i>
    <span id="errorMsg">Failed to load analytics data.</span>
</div>

<!-- ── KPI Cards ── -->
<div class="stats-grid" id="statsGrid">
    <div class="analytics-skeleton"><i class="fa-solid fa-spinner fa-spin"></i> Loading...</div>
</div>

<!-- ── Charts ── -->
<div class="charts-grid" id="chartsGrid" style="display:none;">
    <div class="chart-card">
        <h3><i class="fa-solid fa-chart-area" style="margin-right:0.4rem;"></i>Daily Visits — Last 30 Days</h3>
        <canvas id="trendChart"></canvas>
    </div>
    <div class="chart-card">
        <h3><i class="fa-solid fa-mobile-screen-button" style="margin-right:0.4rem;"></i>Device Breakdown</h3>
        <canvas id="deviceChart"></canvas>
    </div>
</div>

<!-- ── Top Pages ── -->
<div class="table-card" id="topPagesCard" style="display:none;">
    <h3><i class="fa-solid fa-fire" style="margin-right:0.4rem;"></i>Top Pages — Last 30 Days</h3>
    <ul class="top-pages-list" id="topPagesList"></ul>
</div>

<!-- Chart.js (loaded from CDN — no npm dependency) -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

<script>
    let trendChartInstance = null;
    let deviceChartInstance = null;

    const CHART_COLORS = {
        primary:   'rgba(78, 201, 176, 1)',
        primaryBg: 'rgba(78, 201, 176, 0.15)',
        secondary: 'rgba(86, 156, 214, 1)',
        accent:    'rgba(197, 134, 192, 1)',
        warn:      'rgba(220, 180, 80, 1)',
        grid:      'rgba(255, 255, 255, 0.05)',
        text:      'rgba(255, 255, 255, 0.5)',
    };

    const DEVICE_COLORS = [CHART_COLORS.primary, CHART_COLORS.secondary, CHART_COLORS.accent, CHART_COLORS.warn];

    Chart.defaults.color = CHART_COLORS.text;
    Chart.defaults.borderColor = CHART_COLORS.grid;
    Chart.defaults.font.family = 'Inter, sans-serif';

    async function loadAnalytics() {
        const refreshBtn  = document.getElementById('refreshBtn');
        const refreshIcon = document.getElementById('refreshIcon');
        const errorState  = document.getElementById('errorState');

        refreshBtn.classList.add('loading');
        errorState.style.display = 'none';

        try {
            const res = await fetch('/admin/analytics/data', {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const data = await res.json();

            renderStatCards(data);
            renderTrendChart(data.dailyTrend || []);
            renderDeviceChart(data.deviceBreakdown || []);
            renderTopPages(data.topPages || []);

            document.getElementById('chartsGrid').style.display  = 'grid';
            document.getElementById('topPagesCard').style.display = 'block';

        } catch (err) {
            document.getElementById('errorMsg').textContent = `Failed to load analytics: ${err.message}`;
            errorState.style.display = 'block';
            console.error('Analytics load error:', err);
        } finally {
            refreshBtn.classList.remove('loading');
        }
    }

    function renderStatCards(data) {
        const cards = [
            { icon: 'fa-eye',      label: 'Visits Today',        value: fmt(data.totalVisitsToday),   sub: 'page views' },
            { icon: 'fa-user',     label: 'Unique Today',         value: fmt(data.uniqueVisitorsToday),sub: 'distinct visitors' },
            { icon: 'fa-calendar-week', label: 'This Week',       value: fmt(data.totalVisitsThisWeek), sub: 'last 7 days' },
            { icon: 'fa-calendar', label: 'This Month',           value: fmt(data.totalVisitsThisMonth),sub: 'last 30 days' },
        ];
        document.getElementById('statsGrid').innerHTML = cards.map(c => `
            <div class="stat-card">
                <div class="icon"><i class="fa-solid ${c.icon}"></i></div>
                <div class="label">${c.label}</div>
                <div class="value">${c.value}</div>
                <div class="sub">${c.sub}</div>
            </div>
        `).join('');
    }

    function renderTrendChart(trend) {
        const labels = trend.map(d => {
            const [y, m, day] = (d.date || '').split('-');
            return `${day}/${m}`;
        });
        const visits  = trend.map(d => d.visits || 0);
        const uniques = trend.map(d => d.uniqueVisitors || 0);

        if (trendChartInstance) trendChartInstance.destroy();

        trendChartInstance = new Chart(document.getElementById('trendChart'), {
            type: 'line',
            data: {
                labels,
                datasets: [
                    {
                        label: 'Total Visits',
                        data: visits,
                        borderColor: CHART_COLORS.primary,
                        backgroundColor: CHART_COLORS.primaryBg,
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 2,
                        pointHoverRadius: 5,
                    },
                    {
                        label: 'Unique Visitors',
                        data: uniques,
                        borderColor: CHART_COLORS.secondary,
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        fill: false,
                        tension: 0.4,
                        pointRadius: 2,
                        pointHoverRadius: 5,
                        borderDash: [4, 3],
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                interaction: { mode: 'index', intersect: false },
                plugins: { legend: { labels: { boxWidth: 12, font: { size: 11 } } } },
                scales: {
                    x: { grid: { color: CHART_COLORS.grid }, ticks: { maxRotation: 0, autoSkip: true, maxTicksLimit: 8 } },
                    y: { grid: { color: CHART_COLORS.grid }, beginAtZero: true, ticks: { precision: 0 } }
                }
            }
        });
    }

    function renderDeviceChart(breakdown) {
        const labels = breakdown.map(d => `${d.deviceType} (${d.percentage}%)`);
        const counts = breakdown.map(d => d.count);

        if (deviceChartInstance) deviceChartInstance.destroy();

        deviceChartInstance = new Chart(document.getElementById('deviceChart'), {
            type: 'doughnut',
            data: {
                labels,
                datasets: [{
                    data: counts,
                    backgroundColor: DEVICE_COLORS,
                    borderColor: 'rgba(10,10,10,0.8)',
                    borderWidth: 3,
                    hoverOffset: 6,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 12, padding: 16, font: { size: 11 } }
                    }
                }
            }
        });
    }

    function renderTopPages(pages) {
        if (!pages.length) {
            document.getElementById('topPagesList').innerHTML =
                '<li style="color: var(--text-muted); justify-content: center; padding: 1rem;">No data yet.</li>';
            return;
        }
        const max = pages[0]?.visitCount || 1;
        document.getElementById('topPagesList').innerHTML = pages.map((p, i) => `
            <li>
                <span class="page-rank">${i + 1}</span>
                <span class="page-path">${escapeHtml(p.path)}</span>
                <div class="page-bar-wrap">
                    <div class="page-bar" style="width:${Math.round((p.visitCount / max) * 100)}%"></div>
                </div>
                <span class="page-count">${fmt(p.visitCount)}</span>
            </li>
        `).join('');
    }

    function fmt(n) {
        if (n == null) return '—';
        if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
        return n.toString();
    }

    function escapeHtml(str) {
        const d = document.createElement('div');
        d.appendChild(document.createTextNode(str));
        return d.innerHTML;
    }

    // Load on page ready
    document.addEventListener('DOMContentLoaded', loadAnalytics);
</script>
