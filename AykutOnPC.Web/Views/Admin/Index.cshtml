@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<h1 style="margin-bottom: 2rem;">System Status</h1>

<div class="grid">
    <div class="card">
        <h3>System</h3>
        <p style="color: #4ec9b0">Online</p>
    </div>
    <div class="card">
        <h3>AI Status</h3>
        <p style="color: #4ec9b0">Ready</p>
    </div>
    <div class="card">
        <h3>Database</h3>
        <p style="color: #4ec9b0">Connected</p>
    </div>
</div>

<div style="margin-top: 3rem; background: var(--bg-card); padding: 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05);">
    <h3>Welcome back, Admin.</h3>
    <p>Use the sidebar to manage your Knowledge Base and Skills.</p>
</div>
