@model AykutOnPC.Core.Entities.Education
@{
    ViewData["Title"] = "Add Education";
    Layout = "_AdminLayout";
}

<h1 style="margin-bottom: 2rem;">Add Education</h1>

<div class="card" style="max-width: 800px; height: auto; max-height: none; overflow: visible;">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" style="color: #ef4444; margin-bottom: 1rem;"></div>
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Institution / School *</label>
                <input asp-for="Institution" class="form-control" placeholder="Istanbul Technical University" required />
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Degree *</label>
                <input asp-for="Degree" class="form-control" placeholder="Bachelor's Degree" required />
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Field of Study</label>
                <input asp-for="FieldOfStudy" class="form-control" placeholder="Computer Engineering" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Start Date *</label>
                    <input asp-for="StartDate" class="form-control" type="date" required />
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">End Date (Leave empty if current)</label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                </div>
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Grade / GPA (Optional)</label>
                <input asp-for="Grade" class="form-control" placeholder="3.80 / 4.00" />
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Description (Optional)</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Thesis topic, major projects, honors..."></textarea>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-save"></i> Save Education
                </button>
                <a asp-action="Index" class="btn-primary" style="background: rgba(255,255,255,0.05);">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>

<style>
    .form-control {
        width: 100%;
        padding: 0.75rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        color: white;
        font-family: inherit;
    }
    .form-control:focus {
        outline: none;
        border-color: var(--primary);
    }
</style>
