@model IEnumerable<AykutOnPC.Core.Entities.Education>
@{
    ViewData["Title"] = "Education Management";
    Layout = "_AdminLayout";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>Education History</h1>
    <a asp-action="Create" class="btn-primary">
        <i class="fa-solid fa-plus"></i> Add Education
    </a>
</div>

@if (!Model.Any())
{
    <div class="card" style="text-align: center; padding: 3rem;">
        <i class="fa-solid fa-graduation-cap" style="font-size: 3rem; opacity: 0.3; margin-bottom: 1rem;"></i>
        <h3 style="color: var(--text-muted);">No education entries yet</h3>
        <p style="color: var(--text-muted);">Add your educational background to display on the homepage.</p>
    </div>
}
else
{
    <div style="display: flex; flex-direction: column; gap: 1rem;">
        @foreach (var edu in Model)
        {
            <div class="card" style="display: flex; justify-content: space-between; align-items: start;">
                <div style="flex: 1;">
                    <h3>@edu.Degree</h3>
                    <p style="color: var(--secondary); margin: 0.5rem 0;">@edu.Institution @(!string.IsNullOrEmpty(edu.FieldOfStudy) ? $"- {edu.FieldOfStudy}" : "")</p>
                    <p style="color: var(--text-muted); font-size: 0.9rem;">
                        @edu.StartDate.ToString("MMM yyyy") - @(edu.EndDate.HasValue ? edu.EndDate.Value.ToString("MMM yyyy") : "Present")
                    </p>
                    @if (!string.IsNullOrEmpty(edu.Grade))
                    {
                        <p style="color: var(--primary); font-size: 0.9rem; font-weight: 600;">Grade: @edu.Grade</p>
                    }
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <a asp-action="Edit" asp-route-id="@edu.Id" class="btn-primary" style="padding: 0.5rem 1rem;">
                        <i class="fa-solid fa-edit"></i>
                    </a>
                    <form asp-action="Delete" asp-route-id="@edu.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this education entry?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-primary" style="padding: 0.5rem 1rem; background: rgba(239, 68, 68, 0.2); border-color: #ef4444;">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
