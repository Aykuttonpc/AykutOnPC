@{
    ViewData["Title"] = "System Access";
    Layout = null; // Standalone page
}
@*
    AOPC-Sentry Login
    --------------------------------------------------------------------------
    Visual concept: a small holographic SVG robot stands beside the login
    form. Its head, eyes and arms react to what you focus:
      - default          → looks at the user, gently floating
      - username focus   → leans toward the input, eyes lock on
      - password focus   → turns its head AWAY 90°, covers its eyes with
                           both arms ("ben görmüyorum, vallahi")
      - error            → glitch shake + red eye flash
      - success          → cyan eye pulse + slight bow before redirect

    Pure SVG + CSS transforms + a tiny inline JS — no extra dependencies.
    Mobile (<720px) drops the robot column and shows the form alone.
    The honeypot input + anti-CSRF token + autocomplete settings from the
    server-side hardening commits are kept verbatim.
*@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>System Access — AykutOnPC</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        /* ─── Page shell ────────────────────────────────────────────── */
        body {
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background:
                radial-gradient(ellipse at 30% 20%, rgba(109, 40, 217, 0.18), transparent 55%),
                radial-gradient(ellipse at 75% 80%, rgba(6, 182, 212, 0.14),  transparent 55%),
                var(--bg-dark);
            overflow: hidden;
            position: relative;
        }
        body::before {
            /* faint scan-grid overlay */
            content: "";
            position: fixed; inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size: 38px 38px;
            mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
            pointer-events: none;
        }
        body::after {
            /* slow CRT scanlines */
            content: "";
            position: fixed; inset: 0;
            background: repeating-linear-gradient(0deg,
                rgba(255,255,255,0.02) 0,
                rgba(255,255,255,0.02) 1px,
                transparent 1px,
                transparent 4px);
            pointer-events: none;
            mix-blend-mode: overlay;
        }

        .access-wrap {
            display: grid;
            grid-template-columns: minmax(220px, 320px) minmax(320px, 420px);
            gap: 3rem;
            align-items: center;
            padding: 2rem;
            position: relative;
            z-index: 1;
        }
        @@media (max-width: 760px) {
            .access-wrap { grid-template-columns: 1fr; gap: 1rem; }
            .robot-stage { display: none; }
        }

        /* ─── Robot stage ───────────────────────────────────────────── */
        .robot-stage {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 380px;
        }
        .robot-stage::before {
            /* floor halo */
            content: "";
            position: absolute;
            bottom: -10px; left: 50%;
            transform: translateX(-50%);
            width: 220px; height: 28px;
            background: radial-gradient(ellipse, rgba(6,182,212,0.35), transparent 70%);
            filter: blur(4px);
            animation: shadow-pulse 3s ease-in-out infinite;
        }
        @@keyframes shadow-pulse {
            0%, 100% { transform: translateX(-50%) scaleX(1);    opacity: .6; }
            50%      { transform: translateX(-50%) scaleX(0.85); opacity: .9; }
        }

        .robot {
            width: 260px;
            animation: float 4s ease-in-out infinite;
        }
        @@keyframes float {
            0%, 100% { transform: translateY(0); }
            50%      { transform: translateY(-8px); }
        }

        /* head pivots from neck */
        .robot-head {
            transform-origin: 50% 100%;
            transition: transform 0.55s cubic-bezier(.65,-0.2,.35,1.4);
        }
        /* arms pivot from shoulder */
        .robot-arm.left  { transform-origin: 90px  178px; transition: transform 0.45s cubic-bezier(.65,-0.2,.35,1.4); }
        .robot-arm.right { transform-origin: 170px 178px; transition: transform 0.45s cubic-bezier(.65,-0.2,.35,1.4); }

        /* eye pupils translate to follow mouse — overridden by states */
        .robot-pupil {
            transition: transform 0.25s ease, fill 0.3s, opacity 0.25s;
        }
        .robot-eye-glow {
            transition: opacity 0.3s, fill 0.3s;
        }
        .robot-mouth {
            transition: d 0.4s ease, stroke 0.4s;
        }
        .robot-antenna-tip {
            animation: antenna-blink 1.6s ease-in-out infinite;
        }
        @@keyframes antenna-blink {
            0%, 100% { fill: var(--secondary); filter: drop-shadow(0 0 4px var(--secondary)); }
            50%      { fill: var(--primary-glow); filter: drop-shadow(0 0 8px var(--primary-glow)); }
        }

        /* ─── State: USERNAME focus — leans toward form (right) ─────── */
        .robot.is-username .robot-head { transform: rotate(6deg) translateX(4px); }
        .robot.is-username .robot-pupil { transform: translate(3px, -1px) scale(0.85); }

        /* ─── State: PASSWORD focus — turns away (LEFT, away from form) + covers eyes ─────── */
        .robot.is-password .robot-head {
            transform: rotate(-28deg) translate(-18px, -4px);
        }
        .robot.is-password .robot-pupil { opacity: 0; }
        .robot.is-password .robot-eye-glow { opacity: 0.25; }
        .robot.is-password .robot-arm.left  { transform: translate(40px, -55px) rotate(-50deg); }
        .robot.is-password .robot-arm.right { transform: translate(-30px, -55px) rotate(65deg); }

        /* ─── State: TYPING — antennae go faster ───────────────────── */
        .robot.is-typing .robot-antenna-tip { animation-duration: 0.6s; }

        /* ─── State: ERROR — glitch shake + red ────────────────────── */
        .robot.is-error { animation: glitch-shake 0.45s ease both; }
        .robot.is-error .robot-eye-glow { fill: #ef4444; opacity: 1; }
        .robot.is-error .robot-pupil    { fill: #ef4444; }
        @@keyframes glitch-shake {
            0%   { transform: translate(0,0); }
            20%  { transform: translate(-6px, 2px) skewX(-3deg); }
            40%  { transform: translate(5px, -2px) skewX(2deg); }
            60%  { transform: translate(-3px, 1px); }
            80%  { transform: translate(2px, -1px); }
            100% { transform: translate(0,0); }
        }

        /* ─── State: SUCCESS — bow + green flash ───────────────────── */
        .robot.is-success .robot-head { transform: rotate(0) translateY(6px); }
        .robot.is-success .robot-eye-glow { fill: #10b981; opacity: 1; }
        .robot.is-success .robot-pupil    { fill: #10b981; }

        /* ─── Login card ────────────────────────────────────────────── */
        .login-card {
            background: linear-gradient(160deg, rgba(22,22,22,0.92), rgba(10,10,10,0.92));
            backdrop-filter: blur(8px);
            padding: 2.5rem;
            border-radius: 18px;
            border: 1px solid rgba(139, 92, 246, 0.25);
            box-shadow:
                0 0 0 1px rgba(6,182,212,0.06) inset,
                0 30px 60px -30px rgba(109, 40, 217, 0.4),
                0 0 80px -20px rgba(6, 182, 212, 0.25);
            position: relative;
            overflow: hidden;
        }
        .login-card::before {
            /* corner brackets */
            content: "";
            position: absolute; inset: 0;
            background:
                linear-gradient(var(--secondary), var(--secondary)) top    left  / 18px 2px no-repeat,
                linear-gradient(var(--secondary), var(--secondary)) top    left  / 2px 18px no-repeat,
                linear-gradient(var(--secondary), var(--secondary)) top    right / 18px 2px no-repeat,
                linear-gradient(var(--secondary), var(--secondary)) top    right / 2px 18px no-repeat,
                linear-gradient(var(--secondary), var(--secondary)) bottom left  / 18px 2px no-repeat,
                linear-gradient(var(--secondary), var(--secondary)) bottom left  / 2px 18px no-repeat,
                linear-gradient(var(--secondary), var(--secondary)) bottom right / 18px 2px no-repeat,
                linear-gradient(var(--secondary), var(--secondary)) bottom right / 2px 18px no-repeat;
            opacity: 0.5;
            pointer-events: none;
        }

        .access-banner {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            letter-spacing: 0.18em;
            color: var(--secondary);
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.4rem;
        }
        .access-banner::before {
            content: "";
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--secondary);
            box-shadow: 0 0 8px var(--secondary);
            animation: status-pulse 1.4s ease-in-out infinite;
        }
        @@keyframes status-pulse {
            0%, 100% { opacity: 1; }
            50%      { opacity: 0.35; }
        }

        .access-title {
            font-size: 1.6rem;
            font-weight: 700;
            margin: 0 0 0.4rem;
            background: linear-gradient(135deg, #fff, var(--secondary));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .access-subtitle {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin: 0 0 1.5rem;
            font-family: 'JetBrains Mono', monospace;
        }

        .access-error {
            font-family: 'JetBrains Mono', monospace;
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.4);
            color: #fca5a5;
            padding: 0.6rem 0.8rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .access-error::before {
            content: "✕";
            color: #ef4444;
            font-weight: bold;
        }

        .field {
            position: relative;
            margin-bottom: 1rem;
        }
        .field-label {
            position: absolute;
            top: -8px; left: 12px;
            background: var(--bg-dark);
            padding: 0 6px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            letter-spacing: 0.15em;
            color: var(--text-muted);
            text-transform: uppercase;
            transition: color 0.3s;
        }
        .field:focus-within .field-label {
            color: var(--secondary);
        }
        .login-input {
            width: 100%;
            padding: 0.95rem 1rem;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            border-radius: 10px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.95rem;
            transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
            box-sizing: border-box;
        }
        .login-input:focus {
            outline: none;
            border-color: var(--secondary);
            box-shadow: 0 0 0 3px rgba(6,182,212,0.18);
            background: rgba(6, 182, 212, 0.04);
        }
        .login-input::placeholder { color: rgba(255,255,255,0.25); }

        .submit-btn {
            width: 100%;
            margin-top: 1rem;
            padding: 0.95rem 1rem;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            background: linear-gradient(135deg, var(--primary), var(--primary-glow));
            color: white;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            position: relative;
            overflow: hidden;
            transition: transform 0.18s, box-shadow 0.25s;
        }
        .submit-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 30px -10px rgba(139, 92, 246, 0.6);
        }
        .submit-btn:active { transform: translateY(0); }
        .submit-btn::after {
            content: "";
            position: absolute; inset: 0;
            background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.25), transparent 70%);
            transform: translateX(-100%);
            transition: transform 0.7s;
        }
        .submit-btn:hover::after { transform: translateX(100%); }

        .footer-line {
            margin-top: 1.5rem;
            text-align: center;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.1em;
        }
        .footer-line .blink { animation: caret 1.1s steps(2) infinite; }
        @@keyframes caret { 50% { opacity: 0; } }
    </style>
</head>
<body>
    <div class="access-wrap">

        <!-- ─── ROBOT ──────────────────────────────────────────── -->
        <div class="robot-stage" aria-hidden="true">
            <svg id="aopcSentry" class="robot" viewBox="0 0 260 380" xmlns="http://www.w3.org/2000/svg">
                <!-- glow defs -->
                <defs>
                    <radialGradient id="eyeGlow" cx="50%" cy="50%" r="50%">
                        <stop offset="0%"   stop-color="#06b6d4" stop-opacity="1"/>
                        <stop offset="100%" stop-color="#06b6d4" stop-opacity="0"/>
                    </radialGradient>
                    <linearGradient id="bodyGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%"   stop-color="#1f2937"/>
                        <stop offset="100%" stop-color="#0f172a"/>
                    </linearGradient>
                    <linearGradient id="visorGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%"  stop-color="#0e7490"/>
                        <stop offset="100%" stop-color="#1e1b4b"/>
                    </linearGradient>
                </defs>

                <!-- TORSO -->
                <g class="robot-body">
                    <rect x="80" y="170" width="100" height="120" rx="22" fill="url(#bodyGrad)" stroke="#334155" stroke-width="2"/>
                    <!-- chest panel -->
                    <rect x="105" y="200" width="50" height="40" rx="6" fill="#0f172a" stroke="#06b6d4" stroke-opacity="0.35"/>
                    <circle cx="118" cy="220" r="3" fill="#10b981"/>
                    <circle cx="130" cy="220" r="3" fill="#06b6d4"/>
                    <circle cx="142" cy="220" r="3" fill="#8b5cf6"/>
                    <rect x="110" y="228" width="40" height="2" fill="#06b6d4" opacity="0.5"/>
                    <rect x="110" y="232" width="28" height="2" fill="#06b6d4" opacity="0.3"/>

                    <!-- shoulders -->
                    <circle cx="80"  cy="180" r="14" fill="#1f2937" stroke="#475569" stroke-width="2"/>
                    <circle cx="180" cy="180" r="14" fill="#1f2937" stroke="#475569" stroke-width="2"/>
                </g>

                <!-- ARMS (rotate to cover eyes when password focus) -->
                <g class="robot-arm left">
                    <rect x="62" y="178" width="20" height="70" rx="10" fill="#1f2937" stroke="#475569" stroke-width="2"/>
                    <circle cx="72" cy="252" r="11" fill="#0f172a" stroke="#06b6d4" stroke-width="2"/>
                    <!-- pinky finger -->
                    <rect x="69" y="245" width="6" height="10" rx="2" fill="#06b6d4" opacity="0.6"/>
                </g>
                <g class="robot-arm right">
                    <rect x="178" y="178" width="20" height="70" rx="10" fill="#1f2937" stroke="#475569" stroke-width="2"/>
                    <circle cx="188" cy="252" r="11" fill="#0f172a" stroke="#06b6d4" stroke-width="2"/>
                    <rect x="185" y="245" width="6" height="10" rx="2" fill="#06b6d4" opacity="0.6"/>
                </g>

                <!-- NECK -->
                <rect x="118" y="155" width="24" height="20" fill="#334155"/>
                <rect x="118" y="155" width="24" height="6"  fill="#475569"/>

                <!-- HEAD GROUP (rotates) -->
                <g class="robot-head">
                    <!-- antennae -->
                    <line x1="105" y1="55" x2="98"  y2="30" stroke="#475569" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="155" y1="55" x2="162" y2="30" stroke="#475569" stroke-width="2.5" stroke-linecap="round"/>
                    <circle class="robot-antenna-tip" cx="98"  cy="28" r="5" fill="#06b6d4"/>
                    <circle class="robot-antenna-tip" cx="162" cy="28" r="5" fill="#06b6d4" style="animation-delay:0.4s"/>

                    <!-- head shell -->
                    <rect x="80" y="55" width="100" height="100" rx="22" fill="url(#bodyGrad)" stroke="#475569" stroke-width="2"/>
                    <!-- side plates -->
                    <rect x="76" y="85" width="6" height="40" rx="2" fill="#334155"/>
                    <rect x="178" y="85" width="6" height="40" rx="2" fill="#334155"/>

                    <!-- visor -->
                    <rect x="92" y="80" width="76" height="38" rx="8" fill="url(#visorGrad)" stroke="#06b6d4" stroke-opacity="0.6"/>

                    <!-- eye glows -->
                    <circle class="robot-eye-glow" cx="112" cy="99" r="14" fill="url(#eyeGlow)" opacity="1"/>
                    <circle class="robot-eye-glow" cx="148" cy="99" r="14" fill="url(#eyeGlow)" opacity="1" style="animation-delay:0.2s"/>

                    <!-- eye core/pupil -->
                    <circle class="robot-pupil" cx="112" cy="99" r="5" fill="#22d3ee"/>
                    <circle class="robot-pupil" cx="148" cy="99" r="5" fill="#22d3ee"/>

                    <!-- visor scan line -->
                    <rect x="92" y="98" width="76" height="1" fill="rgba(255,255,255,0.4)"/>

                    <!-- mouth grill -->
                    <g>
                        <rect x="115" y="132" width="30" height="9" rx="3" fill="#0f172a" stroke="#475569" stroke-width="1"/>
                        <line x1="120" y1="135" x2="120" y2="139" stroke="#06b6d4" stroke-width="1"/>
                        <line x1="125" y1="135" x2="125" y2="139" stroke="#06b6d4" stroke-width="1"/>
                        <line x1="130" y1="135" x2="130" y2="139" stroke="#06b6d4" stroke-width="1"/>
                        <line x1="135" y1="135" x2="135" y2="139" stroke="#06b6d4" stroke-width="1"/>
                        <line x1="140" y1="135" x2="140" y2="139" stroke="#06b6d4" stroke-width="1"/>
                    </g>
                </g>
            </svg>
        </div>

        <!-- ─── LOGIN CARD ─────────────────────────────────────── -->
        <div class="login-card">
            <div class="access-banner">SYS · AOPC-SENTRY · V1</div>
            <h1 class="access-title">Authenticate</h1>
            <p class="access-subtitle">// secure channel established</p>

            @if (ViewBag.Error != null)
            {
                <div class="access-error">@ViewBag.Error</div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="access-error">@Html.ValidationSummary(false, "", new { @class = "text-danger" })</div>
            }

            <form id="loginForm" method="post" autocomplete="off" novalidate>
                @Html.AntiForgeryToken()

                <div class="field">
                    <label class="field-label" for="login-username">Identity</label>
                    <input id="login-username" type="text" name="username" class="login-input" placeholder="aykut" required autocomplete="off" />
                </div>

                <div class="field">
                    <label class="field-label" for="login-password">Passkey</label>
                    <input id="login-password" type="password" name="password" class="login-input" placeholder="••••••••" required autocomplete="new-password" />
                </div>

                @* Honeypot — invisible to humans, irresistible to bots. Server silently rejects any non-empty value. *@
                <div aria-hidden="true" style="position: absolute; left: -10000px; top: auto; width: 1px; height: 1px; overflow: hidden;">
                    <label for="aop_website">Leave this field empty</label>
                    <input type="text" id="aop_website" name="Website" tabindex="-1" autocomplete="off" />
                </div>

                <button type="submit" class="submit-btn">Initialize Session →</button>
            </form>

            <div class="footer-line">
                ENCRYPTED · TLS · ZERO-LOG <span class="blink">_</span>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const robot   = document.getElementById('aopcSentry');
            const userEl  = document.getElementById('login-username');
            const passEl  = document.getElementById('login-password');
            const formEl  = document.getElementById('loginForm');

            function setState(state) {
                robot.classList.remove('is-username', 'is-password', 'is-typing', 'is-error', 'is-success');
                if (state) robot.classList.add(state);
            }

            userEl.addEventListener('focus', () => setState('is-username'));
            passEl.addEventListener('focus', () => setState('is-password'));
            userEl.addEventListener('blur',  () => { if (document.activeElement !== passEl) setState(null); });
            passEl.addEventListener('blur',  () => { if (document.activeElement !== userEl) setState(null); });

            // typing animation flicker — only on the focused field
            let typingTimer;
            function pulseTyping() {
                robot.classList.add('is-typing');
                clearTimeout(typingTimer);
                typingTimer = setTimeout(() => robot.classList.remove('is-typing'), 400);
            }
            userEl.addEventListener('input', pulseTyping);
            passEl.addEventListener('input', pulseTyping);

            // If the server rendered an error message, do an error glitch on load
            if (document.querySelector('.access-error')) {
                setTimeout(() => {
                    setState('is-error');
                    setTimeout(() => setState(null), 800);
                }, 200);
            }

            // On submit: assume success-bow until the page either redirects or re-renders with error.
            formEl.addEventListener('submit', () => setState('is-success'));
        })();
    </script>
</body>
</html>
