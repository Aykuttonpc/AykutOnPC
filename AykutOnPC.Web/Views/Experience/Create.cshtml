@model AykutOnPC.Core.Entities.Experience
@{
    ViewData["Title"] = "Add Experience";
    Layout = "_AdminLayout";
}

<h1 style="margin-bottom: 2rem;">Add Work Experience</h1>

<div class="card" style="max-width: 800px; height: auto; max-height: none; overflow: visible;">
    <form asp-action="Create" method="post">
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Position / Job Title *</label>
                <input asp-for="Position" class="form-control" placeholder="Senior Software Engineer" required />
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Company *</label>
                <input asp-for="Company" class="form-control" placeholder="Microsoft" required />
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Company Website (Optional)</label>
                <input asp-for="CompanyUrl" class="form-control" type="url" placeholder="https://example.com" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Start Date *</label>
                    <input asp-for="StartDate" class="form-control" type="date" required />
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">End Date (Leave empty if current)</label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                </div>
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Description *</label>
                <textarea asp-for="Description" class="form-control" rows="5" 
                          placeholder="Describe your role, responsibilities, and achievements..." required></textarea>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-save"></i> Save Experience
                </button>
                <a asp-action="Index" class="btn-primary" style="background: rgba(255,255,255,0.05);">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>

<style>
    .form-control {
        width: 100%;
        padding: 0.75rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        color: white;
        font-family: inherit;
    }
    .form-control:focus {
        outline: none;
        border-color: var(--primary);
    }
</style>
