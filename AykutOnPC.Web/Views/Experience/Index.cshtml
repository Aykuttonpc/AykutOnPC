@model IEnumerable<AykutOnPC.Core.Entities.Experience>
@{
    ViewData["Title"] = "Experience Management";
    Layout = "_AdminLayout";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>Experience Timeline</h1>
    <a asp-action="Create" class="btn-primary">
        <i class="fa-solid fa-plus"></i> Add Experience
    </a>
</div>

@if (!Model.Any())
{
    <div class="card" style="text-align: center; padding: 3rem;">
        <i class="fa-solid fa-briefcase" style="font-size: 3rem; opacity: 0.3; margin-bottom: 1rem;"></i>
        <h3 style="color: var(--text-muted);">No experience entries yet</h3>
        <p style="color: var(--text-muted);">Add your first work experience to display on the homepage.</p>
    </div>
}
else
{
    <div style="display: flex; flex-direction: column; gap: 1rem;">
        @foreach (var exp in Model)
        {
            <div class="card" style="display: flex; justify-content: space-between; align-items: start;">
                <div style="flex: 1;">
                    <h3>@exp.Position</h3>
                    <p style="color: var(--secondary); margin: 0.5rem 0;">@exp.Company</p>
                    <p style="color: var(--text-muted); font-size: 0.9rem;">
                        @exp.StartDate.ToString("MMM yyyy") - @(exp.EndDate.HasValue ? exp.EndDate.Value.ToString("MMM yyyy") : "Present")
                    </p>
                    <p style="margin-top: 1rem; line-height: 1.6;">@exp.Description</p>
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <a asp-action="Edit" asp-route-id="@exp.Id" class="btn-primary" style="padding: 0.5rem 1rem;">
                        <i class="fa-solid fa-edit"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@exp.Id" class="btn-primary" 
                       style="padding: 0.5rem 1rem; background: rgba(239, 68, 68, 0.2); border-color: #ef4444;"
                       onclick="return confirm('Are you sure you want to delete this experience?')">
                        <i class="fa-solid fa-trash"></i>
                    </a>
                </div>
            </div>
        }
    </div>
}
