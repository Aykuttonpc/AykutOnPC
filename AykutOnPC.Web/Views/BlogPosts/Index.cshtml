@model IReadOnlyList<AykutOnPC.Core.Entities.BlogPost>

@{
    ViewData["Title"] = "Blog Posts";
    Layout = "_AdminLayout";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>Blog Posts</h1>
    <a asp-action="Create" class="btn-primary"><i class="fa-solid fa-plus"></i> New Post</a>
</div>

<div class="grid" style="grid-template-columns: 1fr;">
    @foreach (var post in Model)
    {
        <div class="card" style="height: auto; max-height: none; flex-direction: row; align-items: center; justify-content: space-between;">
            <div>
                <h3 style="margin-bottom: 0.5rem; color: var(--secondary);">
                    @post.Title
                    @if (post.IsPublished)
                    {
                        <span style="font-size: 0.7rem; color: #10b981; margin-left: 0.5rem;">● Published</span>
                    }
                    else
                    {
                        <span style="font-size: 0.7rem; color: #f59e0b; margin-left: 0.5rem;">● Draft</span>
                    }
                </h3>
                <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem;">
                    /blog/@post.Slug
                </p>
                <small style="color: #666;">
                    Created: @post.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC
                    @if (post.PublishedAtUtc is not null)
                    {
                        <text> · Published: @post.PublishedAtUtc.Value.ToString("yyyy-MM-dd")</text>
                    }
                    @if (!string.IsNullOrWhiteSpace(post.Tags))
                    {
                        <text> · Tags: @post.Tags</text>
                    }
                </small>
            </div>
            <div style="display: flex; gap: 1rem;">
                @if (post.IsPublished)
                {
                    <a asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug" target="_blank" style="color: var(--text-muted);" title="View public"><i class="fa-solid fa-external-link"></i></a>
                }
                <a asp-action="Edit" asp-route-id="@post.Id" style="color: var(--primary);"><i class="fa-solid fa-pen"></i></a>
                <form asp-action="Delete" asp-route-id="@post.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu yazıyı silmek istediğinden emin misin?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" style="color: #ef4444; background: none; border: none; cursor: pointer; padding: 0;">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </form>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <p style="color: var(--text-muted); text-align: center; padding: 3rem 0;">Henüz blog yazısı yok. Yukarıdan yeni bir tane ekleyebilirsin.</p>
    }
</div>
