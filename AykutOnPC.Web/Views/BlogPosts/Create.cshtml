@model AykutOnPC.Core.DTOs.CreateBlogPostDto

@{
    ViewData["Title"] = "New Blog Post";
    Layout = "_AdminLayout";
}

<h1 style="margin-bottom: 2rem;">New Blog Post</h1>

<div class="card" style="height: auto; max-height: none;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div style="margin-bottom: 1.5rem;">
            <label style="display: block; margin-bottom: 0.5rem; color: var(--secondary);">Title</label>
            <input asp-for="Title" class="form-control" style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px;" required />
            <span asp-validation-for="Title" style="color: #ef4444; font-size: 0.85rem;"></span>
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label style="display: block; margin-bottom: 0.5rem; color: var(--secondary);">Slug <small style="color: var(--text-muted);">(boş bırak → başlıktan üretilir)</small></label>
            <input asp-for="Slug" class="form-control" style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px;" placeholder="ornek-yazi-basligi" />
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label style="display: block; margin-bottom: 0.5rem; color: var(--secondary);">Excerpt <small style="color: var(--text-muted);">(opsiyonel, listing'de görünür)</small></label>
            <textarea asp-for="Excerpt" rows="2" class="form-control" style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px;"></textarea>
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label style="display: block; margin-bottom: 0.5rem; color: var(--secondary);">Content (Markdown)</label>
            <textarea asp-for="Content" rows="14" class="form-control" style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px; font-family: monospace;" placeholder="# Başlık&#10;&#10;Markdown ile yazabilirsin. **kalın**, *italik*, `kod`, [link](https://...), liste, tablo." required></textarea>
            <span asp-validation-for="Content" style="color: #ef4444; font-size: 0.85rem;"></span>
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label style="display: block; margin-bottom: 0.5rem; color: var(--secondary);">Tags (virgülle ayırılmış)</label>
            <input asp-for="Tags" class="form-control" style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px;" placeholder=".net, mimari, react" />
        </div>

        <div style="margin-bottom: 2rem;">
            <label style="color: var(--secondary); display: flex; gap: 0.5rem; align-items: center; cursor: pointer;">
                <input asp-for="IsPublished" type="checkbox" /> <span>Hemen yayınla</span>
            </label>
        </div>

        <div style="display: flex; gap: 1rem;">
            <button type="submit" class="btn-primary">Save</button>
            <a asp-action="Index" style="padding: 1rem 2rem; color: var(--text-muted); text-decoration: none;">Cancel</a>
        </div>
    </form>
</div>
