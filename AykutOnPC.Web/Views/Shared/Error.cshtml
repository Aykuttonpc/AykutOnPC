@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<section style="min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 4rem 2rem;">
    <div style="text-align: center; max-width: 560px;">
        <div style="font-size: 6rem; line-height: 1; color: var(--secondary); margin-bottom: 1rem;">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">Bir şeyler ters gitti</h1>
        <p style="color: var(--text-muted); margin-bottom: 2rem;">
            İsteğini işlerken beklenmedik bir hata oluştu. Birkaç saniye sonra tekrar dene.
            Sorun devam ederse anasayfadan yeniden başlayabilirsin.
        </p>

        @if (Model.ShowRequestId)
        {
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 2rem;">
                Hata referansı: <code style="background: rgba(255,255,255,0.05); padding: 0.15rem 0.4rem; border-radius: 4px;">@Model.RequestId</code>
            </p>
        }

        <a asp-controller="Home" asp-action="Index"
           style="display: inline-block; padding: 0.75rem 1.5rem; background: var(--primary); color: #fff; text-decoration: none; border-radius: 6px; transition: opacity 0.2s;"
           onmouseover="this.style.opacity='0.85';"
           onmouseout="this.style.opacity='1';">
            <i class="fa-solid fa-house" style="margin-right: 0.5rem;"></i>Anasayfaya dön
        </a>
    </div>
</section>
