<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AykutOnPC</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- AOS CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <!-- Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="particles-js"></div>

    <nav class="navbar">
        <a asp-controller="Home" asp-action="Index" class="nav-brand">AykutOnPC</a>
        <div class="nav-links">
            <a href="#builds" class="nav-link">Projects</a>
            <a href="#specs" class="nav-link">Skills</a>
            <a href="#" class="nav-link">About</a>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer style="text-align: center; padding: 2rem; color: var(--text-muted); opacity: 0.5;">
        &copy; 2026 AykutOnPC. Powered by .NET 9 & AI. | <a asp-controller="Admin" asp-action="Index" style="color: var(--text-muted); text-decoration: none;">Admin</a>
    </footer>

    <partial name="_AIWidget" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- Cyberpunk UI Scripts -->
    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/howler/2.2.3/howler.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.0/vanilla-tilt.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() {
            // Widget Toggle
            $('#ai-trigger-btn').click(function() {
                $('#ai-widget-container').toggleClass('active');
                $(this).toggleClass('active');
            });
            
            $('#close-ai-widget').click(function() {
                $('#ai-widget-container').removeClass('active');
            });

            // Send Message Logic
            async function sendMessage() {
                var input = $('#ai-input');
                var message = input.val().trim();
                var btn = $('#ai-send-btn');
                
                if(!message) return;

                // UI Updates
                input.val('');
                input.prop('disabled', true);
                btn.prop('disabled', true);
                
                var container = $('#ai-messages');
                container.append(`<div class="message user-message">${escapeHtml(message)}</div>`);
                scrollToBottom();

                // Show typing indicator (optional placeholder)
                var loadingId = 'loading-' + Date.now();
                container.append(`<div id="${loadingId}" class="message ai-message"><i class="fa-solid fa-ellipsis fa-fade"></i></div>`);
                scrollToBottom();

                try {
                    const response = await fetch('/api/chat/ask', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ message: message })
                    });
                    
                    const data = await response.json();
                    
                    $(`#${loadingId}`).remove();
                    container.append(`<div class="message ai-message">${linkify(data.response)}</div>`);
                } catch (error) {
                    $(`#${loadingId}`).remove();
                    container.append(`<div class="message ai-message" style="color: #ef4444;">Connection error. Try again.</div>`);
                }

                input.prop('disabled', false);
                btn.prop('disabled', false);
                input.focus();
                scrollToBottom();
            }

            $('#ai-send-btn').click(sendMessage);

            // Helpers
            function scrollToBottom() {
                var div = document.getElementById('ai-messages');
                div.scrollTop = div.scrollHeight;
            }

            function escapeHtml(text) {
                var map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                };
                return text.replace(/[&<>"']/g, function(m) { return map[m]; });
            }
            
            function linkify(text) {
                var urlRegex = /(https?:\/\/[^\s]+)/g;
                return text.replace(urlRegex, function(url) {
                    return '<a href="' + url + '" target="_blank" style="color: var(--secondary); text-decoration: underline;">' + url + '</a>';
                });
            }

            // Enter key to send
            $('#ai-input').keypress(function(e) {
                if(e.which == 13) {
                    sendMessage();
                }
            });

            // ==========================================
            // CYBERPUNK INITIALIZATIONS
            // ==========================================

            // 1. AOS (Animate On Scroll)
            AOS.init({
                duration: 800,
                once: true,
                offset: 100
            });

            // 2. Particles.js Initialization
            if (window.particlesJS) {
                particlesJS('particles-js', {
                    "particles": {
                        "number": { "value": 60, "density": { "enable": true, "value_area": 800 } },
                        "color": { "value": ["#6d28d9", "#06b6d4"] },
                        "shape": { "type": "circle" },
                        "opacity": { "value": 0.5, "random": false },
                        "size": { "value": 3, "random": true },
                        "line_linked": {
                            "enable": true,
                            "distance": 150,
                            "color": "#6d28d9",
                            "opacity": 0.4,
                            "width": 1
                        },
                        "move": {
                            "enable": true,
                            "speed": 2,
                            "direction": "none",
                            "random": false,
                            "straight": false,
                            "out_mode": "out",
                            "bounce": false,
                        }
                    },
                    "interactivity": {
                        "detect_on": "canvas",
                        "events": {
                            "onhover": { "enable": true, "mode": "grab" },
                            "onclick": { "enable": true, "mode": "push" },
                            "resize": true
                        },
                        "modes": {
                            "grab": { "distance": 140, "line_linked": { "opacity": 1 } },
                            "push": { "particles_nb": 4 }
                        }
                    },
                    "retina_detect": true
                });
            }

            // 3. SFX Initialization (Howler)
            // Note: Sounds will only play after the user makes their first interaction (click) due to browser policies.
            const sfxHover = new Howl({
                src: ['https://assets.mixkit.co/active_storage/sfx/2568/2568-preview.mp3'], // Synth slight beep
                volume: 0.1
            });
            const sfxClick = new Howl({
                src: ['https://assets.mixkit.co/active_storage/sfx/2571/2571-preview.mp3'], // Metallic click
                volume: 0.2
            });

            // Bind sound to elements dynamically
            $(document).on('mouseenter', 'a, button, .card', function() {
                try { sfxHover.play(); } catch(e){}
            });
            $(document).on('mousedown', 'a, button', function() {
                try { sfxClick.play(); } catch(e){}
            });

        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
