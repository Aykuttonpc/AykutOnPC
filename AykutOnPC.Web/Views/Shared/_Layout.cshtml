<!DOCTYPE html>
@{
    var pageTitle       = (ViewData["Title"] as string) ?? "AykutOnPC";
    var siteTitle       = "AykutOnPC";
    var fullTitle       = $"{pageTitle} - {siteTitle}";
    var metaDescription = (ViewData["MetaDescription"] as string)
        ?? "AykutOnPC — .NET 9 portfolio of Aykut Çinçik featuring AI chat, real-time analytics and modern cyberpunk design.";
    var metaImage       = (ViewData["MetaImage"] as string) ?? Url.Content("~/images/og-cover.png");
    var canonicalUrl    = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
    var ogType          = (ViewData["OgType"] as string) ?? "website";
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@fullTitle</title>

    <!-- SEO -->
    <meta name="description" content="@metaDescription" />
    <meta name="author" content="Aykut Çinçik" />
    <meta name="theme-color" content="#0a0a0f" />
    <link rel="canonical" href="@canonicalUrl" />

    <!-- Open Graph -->
    <meta property="og:site_name"   content="@siteTitle" />
    <meta property="og:title"       content="@fullTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:type"        content="@ogType" />
    <meta property="og:url"         content="@canonicalUrl" />
    <meta property="og:image"       content="@metaImage" />
    <meta property="og:image:alt"   content="@siteTitle preview" />
    <meta property="og:locale"      content="en_US" />

    <!-- Twitter Cards -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="@fullTitle" />
    <meta name="twitter:description" content="@metaDescription" />
    <meta name="twitter:image"       content="@metaImage" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

    <!-- Icons (SRI pinned to font-awesome 6.4.0) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
          integrity="sha384-iw3OoTErCYJJB9mCa8LNS2hbsQ7M3C0EpIsO/H5+EGAkPGc6rk+V8i04oW/K5xq0"
          crossorigin="anonymous" referrerpolicy="no-referrer">

    <!-- AOS CSS (SRI pinned to aos 2.3.1) -->
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css"
          integrity="sha384-/rJKQnzOkEo+daG0jMjU1IwwY9unxt1NBw3Ef2fmOJ3PW/TfAg2KXVoWwMZQZtw9"
          crossorigin="anonymous">

    <!-- Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/email-picker.css" asp-append-version="true" />

    <!-- RSS feed discovery for blog -->
    <link rel="alternate" type="application/rss+xml" title="AykutOnPC Blog" href="/blog/feed.xml" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <div id="particles-js"></div>

    <nav class="navbar">
        <a asp-controller="Home" asp-action="Index" class="nav-brand">AykutOnPC</a>
        <div class="nav-links">
            <a href="#builds" class="nav-link">Projects</a>
            <a href="#specs" class="nav-link">Skills</a>
            <a href="#" class="nav-link">About</a>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer style="text-align: center; padding: 2rem; color: var(--text-muted); opacity: 0.5;">
        &copy; 2026 AykutOnPC. Powered by .NET 9 & AI.
        <a asp-controller="Admin" asp-action="Index"
           title="Admin"
           aria-label="Admin"
           style="color: var(--text-muted); text-decoration: none; margin-left: 0.6rem; transition: color 0.2s, opacity 0.2s;"
           onmouseover="this.style.color='var(--secondary)'; this.style.opacity='1';"
           onmouseout="this.style.color='var(--text-muted)'; this.style.opacity='';">
            <i class="fa-solid fa-user-shield"></i>
        </a>
    </footer>

    <partial name="_AIWidget" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- Cyberpunk UI Scripts (SRI pinned per file) -->
    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"
            integrity="sha384-d+UOwmNNIC7V4izkTAKSXzWhjC2GxiS9PTykO1XdOPC3nc2z65UOS7SP6QdKPA70"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"
            integrity="sha384-wziAfh6b/qT+3LrqebF9WeK4+J5sehS6FA10J1t3a866kJ/fvU5UwofWnQyzLtwu"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/howler/2.2.3/howler.min.js"
            integrity="sha384-46Oo18A61vfMErbleKnm7no+MU4xWkCYAHfFjdeBgYnq5437neF0hgpBaX/YM8fu"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.0/vanilla-tilt.min.js"
            integrity="sha384-QQEAefmew0Un2GyadO5GSPVijOMu9zSE/p+OM1WgLr8sQp9f5ZXokako48B7Ytiw"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/email-picker.js" asp-append-version="true" defer></script>
    <script>
        $(document).ready(function() {
            // ── Conversation state ───────────────────────────────────
            // ConversationId persists for the browser tab so the server can replay last N
            // turns as memory. Cleared when the tab closes (sessionStorage, not localStorage).
            const CONV_KEY = 'aykutonpc.chat.conversationId';
            let conversationId = sessionStorage.getItem(CONV_KEY) || null;

            // ── Widget toggle ────────────────────────────────────────
            $('#ai-trigger-btn').click(function() {
                $('#ai-widget-container').toggleClass('active');
                $(this).toggleClass('active');
                ensureSuggestionsLoaded();
            });
            $('#close-ai-widget').click(function() {
                $('#ai-widget-container').removeClass('active');
            });

            // ── Suggestion chips ─────────────────────────────────────
            let cachedSuggestions = null;

            async function ensureSuggestionsLoaded() {
                // Welcome-state chips: lazy-fetched once per page so the widget feels instant.
                if (cachedSuggestions !== null) {
                    renderSuggestions(cachedSuggestions);
                    return;
                }
                try {
                    const r = await fetch('/api/chat/suggestions', { method: 'GET' });
                    cachedSuggestions = r.ok ? await r.json() : [];
                } catch (_) {
                    cachedSuggestions = [];
                }
                renderSuggestions(cachedSuggestions);
            }

            function renderSuggestions(list) {
                const $box = $('#ai-suggestions');
                $box.empty();
                if (!list || list.length === 0) return;
                list.forEach(s => {
                    const $chip = $('<button type="button" class="ai-suggestion-chip"></button>')
                        .text(s.label)
                        .on('click', () => {
                            $('#ai-input').val(s.prompt);
                            sendMessage();
                        });
                    $box.append($chip);
                });
            }

            function clearSuggestions() {
                $('#ai-suggestions').empty();
            }

            // ── Status dot ───────────────────────────────────────────
            // Maps server-side ChatErrorKind -> visible status. We only flip the dot when the
            // error is something the user can act on, otherwise keep it green so the widget
            // doesn't pulse red every time the model says "I don't know".
            function setStatus(kind) {
                const map = {
                    'Ok':            { color: '#22c55e', label: 'Online' },
                    'Empty':         { color: '#22c55e', label: 'Online' },
                    'Validation':    { color: '#22c55e', label: 'Online' },
                    'Safety':        { color: '#f59e0b', label: 'Sınırlı' },
                    'RateLimit':     { color: '#f59e0b', label: 'Yoğun' },
                    'Network':       { color: '#ef4444', label: 'Bağlantı zayıf' },
                    'NotConfigured': { color: '#64748b', label: 'Yapılandırılmamış' },
                    'Unknown':       { color: '#ef4444', label: 'Hata' }
                };
                const entry = map[kind] || map['Ok'];
                $('#ai-status-dot').css('background', entry.color);
                $('#ai-status-label').text(entry.label);
            }

            // ── Send message ─────────────────────────────────────────
            async function sendMessage() {
                const input = $('#ai-input');
                const message = input.val().trim();
                const btn = $('#ai-send-btn');

                if(!message) return;

                input.val('');
                input.prop('disabled', true);
                btn.prop('disabled', true);
                clearSuggestions();

                const container = $('#ai-messages');
                container.append(`<div class="message user-message">${escapeHtml(message)}</div>`);
                scrollToBottom();

                const bubbleId = 'ai-' + Date.now();
                container.append(
                    `<div id="${bubbleId}" class="message ai-message" data-raw="">` +
                    `<i class="fa-solid fa-ellipsis fa-fade"></i></div>`
                );
                scrollToBottom();
                const $bubble = $(`#${bubbleId}`);

                let fullText = '';
                let receivedAny = false;
                let terminalKind = null;
                let terminalSuggestions = null;
                let usedFallback = false;

                try {
                    const response = await fetch('/api/chat/stream', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'text/event-stream' },
                        body: JSON.stringify({ message: message, conversationId: conversationId })
                    });

                    if (!response.ok || !response.body) throw new Error('stream-unavailable');

                    const reader  = response.body.getReader();
                    const decoder = new TextDecoder('utf-8');
                    let buffer    = '';
                    let inDoneEvent = false;

                    while (true) {
                        const { value, done } = await reader.read();
                        if (done) break;
                        buffer += decoder.decode(value, { stream: true });

                        let sep;
                        while ((sep = buffer.indexOf('\n\n')) !== -1) {
                            const rawEvent = buffer.slice(0, sep);
                            buffer = buffer.slice(sep + 2);

                            // SSE event format: optional "event: <name>" line, then "data: <json>".
                            // The terminal frame uses "event: done" with a JSON payload carrying
                            // {kind, conversationId, suggestions}.
                            const lines = rawEvent.split('\n');
                            const eventLine = lines.find(l => l.startsWith('event: '));
                            const dataLine  = lines.find(l => l.startsWith('data: '));
                            inDoneEvent = eventLine === 'event: done';

                            if (!dataLine) continue;
                            try {
                                const payload = JSON.parse(dataLine.slice(6));
                                if (inDoneEvent) {
                                    terminalKind        = payload.kind || null;
                                    terminalSuggestions = payload.suggestions || null;
                                    if (payload.conversationId) {
                                        conversationId = payload.conversationId;
                                        sessionStorage.setItem(CONV_KEY, conversationId);
                                    }
                                } else if (payload.t) {
                                    if (!receivedAny) {
                                        $bubble.empty();
                                        receivedAny = true;
                                    }
                                    fullText += payload.t;
                                    $bubble.attr('data-raw', fullText);
                                    $bubble.html(linkify(escapeHtml(fullText)));
                                    scrollToBottom();
                                }
                            } catch (e) { /* ignore malformed event */ }
                        }
                    }

                    if (!receivedAny && terminalKind === null) throw new Error('empty-stream');
                } catch (streamError) {
                    // Fallback: non-streaming endpoint keeps the widget functional behind proxies
                    // that strip SSE. Returns full payload (response + kind + suggestions) at once.
                    usedFallback = true;
                    try {
                        const fallback = await fetch('/api/chat/ask', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ message: message, conversationId: conversationId })
                        });
                        if (!fallback.ok) throw new Error('fallback-' + fallback.status);
                        const data = await fallback.json();
                        $bubble.empty().html(linkify(escapeHtml(data.response || '')));
                        terminalKind        = data.kind || 'Unknown';
                        terminalSuggestions = data.suggestions || null;
                        if (data.conversationId) {
                            conversationId = data.conversationId;
                            sessionStorage.setItem(CONV_KEY, conversationId);
                        }
                    } catch (fatal) {
                        $bubble.empty()
                               .css('color', '#ef4444')
                               .text('Şu an bağlantım zayıf. Lütfen birkaç saniye sonra tekrar dene.');
                        terminalKind = 'Network';
                    }
                }

                // If the bubble is still empty (terminal-only frame from preflight, etc.),
                // fall back to a generic indicator — the message is in the log already.
                if (!receivedAny && !usedFallback && $bubble.html().includes('fa-ellipsis')) {
                    $bubble.empty().text('—');
                }

                setStatus(terminalKind || 'Ok');
                if (terminalSuggestions && terminalSuggestions.length > 0) {
                    renderSuggestions(terminalSuggestions);
                }

                input.prop('disabled', false);
                btn.prop('disabled', false);
                input.focus();
                scrollToBottom();
            }

            $('#ai-send-btn').click(sendMessage);

            // Helpers
            function scrollToBottom() {
                const div = document.getElementById('ai-messages');
                div.scrollTop = div.scrollHeight;
            }

            function escapeHtml(text) {
                const map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                };
                return text.replace(/[&<>"']/g, function(m) { return map[m]; });
            }

            function linkify(text) {
                const urlRegex = /(https?:\/\/[^\s]+)/g;
                return text.replace(urlRegex, function(url) {
                    return '<a href="' + url + '" target="_blank" style="color: var(--secondary); text-decoration: underline;">' + url + '</a>';
                });
            }

            // Enter key to send
            $('#ai-input').keypress(function(e) {
                if(e.which == 13) {
                    sendMessage();
                }
            });

            // ==========================================
            // CYBERPUNK INITIALIZATIONS
            // ==========================================

            // 1. AOS (Animate On Scroll)
            AOS.init({
                duration: 800,
                once: true,
                offset: 100
            });

            // 2. Particles.js Initialization
            if (window.particlesJS) {
                particlesJS('particles-js', {
                    "particles": {
                        "number": { "value": 60, "density": { "enable": true, "value_area": 800 } },
                        "color": { "value": ["#6d28d9", "#06b6d4"] },
                        "shape": { "type": "circle" },
                        "opacity": { "value": 0.5, "random": false },
                        "size": { "value": 3, "random": true },
                        "line_linked": {
                            "enable": true,
                            "distance": 150,
                            "color": "#6d28d9",
                            "opacity": 0.4,
                            "width": 1
                        },
                        "move": {
                            "enable": true,
                            "speed": 2,
                            "direction": "none",
                            "random": false,
                            "straight": false,
                            "out_mode": "out",
                            "bounce": false,
                        }
                    },
                    "interactivity": {
                        "detect_on": "canvas",
                        "events": {
                            "onhover": { "enable": true, "mode": "grab" },
                            "onclick": { "enable": true, "mode": "push" },
                            "resize": true
                        },
                        "modes": {
                            "grab": { "distance": 140, "line_linked": { "opacity": 1 } },
                            "push": { "particles_nb": 4 }
                        }
                    },
                    "retina_detect": true
                });
            }

            // 3. SFX Initialization (Howler)
            // Note: Sounds will only play after the user makes their first interaction (click) due to browser policies.
            const sfxHover = new Howl({
                src: ['https://assets.mixkit.co/active_storage/sfx/2568/2568-preview.mp3'], // Synth slight beep
                volume: 0.1
            });
            const sfxClick = new Howl({
                src: ['https://assets.mixkit.co/active_storage/sfx/2571/2571-preview.mp3'], // Metallic click
                volume: 0.2
            });

            // Bind sound to elements dynamically
            $(document).on('mouseenter', 'a, button, .card', function() {
                try { sfxHover.play(); } catch(e){}
            });
            $(document).on('mousedown', 'a, button', function() {
                try { sfxClick.play(); } catch(e){}
            });

        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
