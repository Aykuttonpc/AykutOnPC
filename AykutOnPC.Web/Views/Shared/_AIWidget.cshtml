<div id="ai-widget-container" class="ai-widget-container">
    <div class="ai-header">
        <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div class="ai-avatar">
                <i class="fa-solid fa-robot"></i>
            </div>
            <div>
                <h4 style="margin: 0; font-size: 1rem;">Aykut's Digital Twin</h4>
                <small style="color: #a3a3a3; font-size: 0.75rem;">Online • AI Powered</small>
            </div>
        </div>
        <button id="close-ai-widget" style="background: none; border: none; color: white; cursor: pointer;">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
    
    <div class="ai-messages" id="ai-messages">
        <div class="message ai-message">
            Merhaba! Ben Aykut'un dijital ikiziyim. 🤖<br>
            Projelerim, yeteneklerim veya benim hakkımda merak ettiğin her şeyi sorabilirsin.
        </div>
    </div>

    <div class="ai-input-area">
        <input type="text" id="ai-input" placeholder="Ask me anything..." autocomplete="off">
        <button id="ai-send-btn">
            <i class="fa-solid fa-paper-plane"></i>
        </button>
    </div>
</div>

<div id="ai-trigger-btn" class="ai-widget-trigger">
    <i class="fa-solid fa-message"></i>
</div>
