@model AykutOnPC.Core.DTOs.PagedResult<AykutOnPC.Core.Entities.ChatLog>
@{
    ViewData["Title"] = "Chat Logs";
    Layout = "_AdminLayout";
    var query = (AykutOnPC.Core.DTOs.ChatLogQueryDto)ViewBag.Query;
    var stats = (AykutOnPC.Core.DTOs.ChatLogStatsDto)ViewBag.Stats;

    string KindBadgeColor(string kind) => kind switch
    {
        "Ok"            => "#22c55e",
        "Empty"         => "#f59e0b",
        "Validation"    => "#f59e0b",
        "Safety"        => "#ec4899",
        "RateLimit"     => "#a855f7",
        "Network"       => "#06b6d4",
        "NotConfigured" => "#64748b",
        _               => "#ef4444"
    };
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h1 style="margin: 0;">Chat Logs</h1>
    <small style="color: var(--text-muted);">Conversations are grouped by ConversationId — click a row to drill into the full thread.</small>
</div>

<!-- ── Stats strip ─────────────────────────────────────── -->
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <div class="card" style="padding: 1.25rem; height: auto; max-height: none;">
        <div style="color: var(--text-muted); font-size: 0.85rem;">Bugün</div>
        <div style="font-size: 2rem; font-weight: 800; color: var(--secondary);">@stats.TotalToday</div>
    </div>
    <div class="card" style="padding: 1.25rem; height: auto; max-height: none;">
        <div style="color: var(--text-muted); font-size: 0.85rem;">Son 7 gün</div>
        <div style="font-size: 2rem; font-weight: 800;">@stats.TotalLast7Days</div>
    </div>
    <div class="card" style="padding: 1.25rem; height: auto; max-height: none;">
        <div style="color: var(--text-muted); font-size: 0.85rem;">Son 30 gün</div>
        <div style="font-size: 2rem; font-weight: 800;">@stats.TotalLast30Days</div>
    </div>
    <div class="card" style="padding: 1.25rem; height: auto; max-height: none;">
        <div style="color: var(--text-muted); font-size: 0.85rem;">Tekil konuşma (7g)</div>
        <div style="font-size: 2rem; font-weight: 800;">@stats.UniqueConversationsLast7Days</div>
    </div>
    <div class="card" style="padding: 1.25rem; height: auto; max-height: none;">
        <div style="color: var(--text-muted); font-size: 0.85rem;">Ort. latency (7g)</div>
        <div style="font-size: 2rem; font-weight: 800;">@stats.AvgLatencyMsLast7Days.ToString("0") <small style="font-size: 0.9rem; color: var(--text-muted);">ms</small></div>
    </div>
</div>

@if (stats.ByKindLast7Days.Count > 0)
{
    <div class="card" style="padding: 1rem 1.25rem; height: auto; max-height: none; margin-bottom: 2rem;">
        <div style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.5rem;">Son 7 günün dağılımı</div>
        <div style="display: flex; gap: 0.6rem; flex-wrap: wrap;">
            @foreach (var pair in stats.ByKindLast7Days.OrderByDescending(p => p.Value))
            {
                <span style="background: rgba(255,255,255,0.05); border: 1px solid @KindBadgeColor(pair.Key); color: @KindBadgeColor(pair.Key); padding: 0.3rem 0.75rem; border-radius: 999px; font-size: 0.85rem;">
                    @pair.Key: @pair.Value
                </span>
            }
        </div>
    </div>
}

<!-- ── Filter form ─────────────────────────────────────── -->
<form method="get" asp-action="Index" class="card" style="height: auto; max-height: none; padding: 1.25rem; margin-bottom: 2rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; align-items: end;">
        <div>
            <label style="display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.4rem;">Başlangıç (UTC)</label>
            <input type="datetime-local" name="fromUtc" value="@(query.FromUtc?.ToString("yyyy-MM-ddTHH:mm"))" class="form-control" />
        </div>
        <div>
            <label style="display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.4rem;">Bitiş (UTC)</label>
            <input type="datetime-local" name="toUtc" value="@(query.ToUtc?.ToString("yyyy-MM-ddTHH:mm"))" class="form-control" />
        </div>
        <div>
            <label style="display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.4rem;">Kind</label>
            <select name="kind" class="form-control">
                <option value="">— hepsi —</option>
                @foreach (var k in new[] { "Ok", "Empty", "Validation", "Safety", "RateLimit", "Network", "NotConfigured", "Unknown" })
                {
                    <option value="@k" selected="@(query.Kind == k)">@k</option>
                }
            </select>
        </div>
        <div>
            <label style="display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.4rem;">Arama (mesaj içinde)</label>
            <input type="text" name="search" value="@query.Search" placeholder="örn. proje" class="form-control" />
        </div>
        <div>
            <button type="submit" class="btn-primary" style="width: 100%;">
                <i class="fa-solid fa-filter"></i> Filtrele
            </button>
        </div>
    </div>
</form>

<!-- ── Results table ───────────────────────────────────── -->
<div class="card" style="height: auto; max-height: none; padding: 0; overflow: hidden;">
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="background: rgba(255,255,255,0.05); text-align: left;">
                <th style="padding: 0.85rem 1rem; font-weight: 600; color: var(--text-muted); font-size: 0.85rem;">Tarih (UTC)</th>
                <th style="padding: 0.85rem 1rem; font-weight: 600; color: var(--text-muted); font-size: 0.85rem;">Kind</th>
                <th style="padding: 0.85rem 1rem; font-weight: 600; color: var(--text-muted); font-size: 0.85rem;">Kullanıcı mesajı</th>
                <th style="padding: 0.85rem 1rem; font-weight: 600; color: var(--text-muted); font-size: 0.85rem;">Bot cevabı</th>
                <th style="padding: 0.85rem 1rem; font-weight: 600; color: var(--text-muted); font-size: 0.85rem; text-align: right;">Latency</th>
                <th style="padding: 0.85rem 1rem; font-weight: 600; color: var(--text-muted); font-size: 0.85rem;">Sohbet</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="6" style="padding: 2rem; text-align: center; color: var(--text-muted);">Filtreyle eşleşen kayıt yok.</td>
                </tr>
            }
            else
            {
                foreach (var row in Model.Items)
                {
                    var userPreview = row.UserMessage.Length > 80 ? row.UserMessage[..80] + "…" : row.UserMessage;
                    var botPreview  = (row.BotResponse ?? "").Length > 120 ? row.BotResponse![..120] + "…" : (row.BotResponse ?? "");
                    <tr style="border-top: 1px solid rgba(255,255,255,0.06);">
                        <td style="padding: 0.85rem 1rem; color: var(--text-muted); font-family: monospace; font-size: 0.85rem; white-space: nowrap;">
                            @row.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")
                        </td>
                        <td style="padding: 0.85rem 1rem;">
                            <span style="background: rgba(0,0,0,0.3); border: 1px solid @KindBadgeColor(row.Kind); color: @KindBadgeColor(row.Kind); padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">
                                @row.Kind
                            </span>
                            @if (row.ShortCircuited)
                            {
                                <small style="color: var(--text-muted); margin-left: 0.4rem;">pre-flight</small>
                            }
                        </td>
                        <td style="padding: 0.85rem 1rem; max-width: 280px;">@userPreview</td>
                        <td style="padding: 0.85rem 1rem; max-width: 380px; color: var(--text-muted);">@botPreview</td>
                        <td style="padding: 0.85rem 1rem; text-align: right; font-family: monospace; color: var(--text-muted);">@row.LatencyMs ms</td>
                        <td style="padding: 0.85rem 1rem;">
                            <a asp-action="Detail" asp-route-conversationId="@row.ConversationId" style="color: var(--secondary);">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i> aç
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- ── Pagination ───────────────────────────────────────── -->
@if (Model.TotalPages > 1)
{
    <div style="display: flex; justify-content: center; align-items: center; gap: 0.6rem; margin-top: 1.5rem;">
        @if (Model.Page > 1)
        {
            <a asp-action="Index" asp-route-fromUtc="@query.FromUtc" asp-route-toUtc="@query.ToUtc"
               asp-route-kind="@query.Kind" asp-route-search="@query.Search" asp-route-page="@(Model.Page - 1)"
               class="btn-primary" style="padding: 0.5rem 1rem;">← Önceki</a>
        }
        <span style="color: var(--text-muted);">Sayfa @Model.Page / @Model.TotalPages — toplam @Model.Total kayıt</span>
        @if (Model.Page < Model.TotalPages)
        {
            <a asp-action="Index" asp-route-fromUtc="@query.FromUtc" asp-route-toUtc="@query.ToUtc"
               asp-route-kind="@query.Kind" asp-route-search="@query.Search" asp-route-page="@(Model.Page + 1)"
               class="btn-primary" style="padding: 0.5rem 1rem;">Sonraki →</a>
        }
    </div>
}

<style>
    .form-control {
        width: 100%;
        padding: 0.6rem 0.75rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 6px;
        color: white;
        font-family: inherit;
        font-size: 0.9rem;
    }
    .form-control:focus { outline: none; border-color: var(--primary); }
</style>
