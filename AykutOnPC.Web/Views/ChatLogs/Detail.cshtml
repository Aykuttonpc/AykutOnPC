@model List<AykutOnPC.Core.Entities.ChatLog>
@{
    ViewData["Title"] = "Conversation Detail";
    Layout = "_AdminLayout";
    var conversationId = (Guid)ViewBag.ConversationId;
    var first = Model.FirstOrDefault();
    var last  = Model.LastOrDefault();

    string KindBadgeColor(string kind) => kind switch
    {
        "Ok"            => "#22c55e",
        "Empty"         => "#f59e0b",
        "Validation"    => "#f59e0b",
        "Safety"        => "#ec4899",
        "RateLimit"     => "#a855f7",
        "Network"       => "#06b6d4",
        "NotConfigured" => "#64748b",
        _               => "#ef4444"
    };
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <div>
        <a asp-action="Index" style="color: var(--text-muted); text-decoration: none; font-size: 0.9rem;">
            <i class="fa-solid fa-arrow-left"></i> Tüm log'lar
        </a>
        <h1 style="margin: 0.4rem 0 0 0;">Sohbet</h1>
        <small style="color: var(--text-muted); font-family: monospace;">@conversationId</small>
    </div>
    <div style="text-align: right; color: var(--text-muted); font-size: 0.85rem;">
        @if (first is not null && last is not null)
        {
            <div>@Model.Count tur · @first.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC başlangıç</div>
            <div>UA: @(string.IsNullOrEmpty(first.UserAgent) ? "—" : (first.UserAgent.Length > 80 ? first.UserAgent[..80] + "…" : first.UserAgent))</div>
            <div>IP hash: <code style="font-size: 0.8rem;">@(first.HashedIp.Length >= 16 ? first.HashedIp[..16] + "…" : first.HashedIp)</code></div>
        }
    </div>
</div>

<div style="display: flex; flex-direction: column; gap: 1.25rem;">
    @foreach (var turn in Model)
    {
        <div class="card" style="height: auto; max-height: none; padding: 1.25rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.85rem; padding-bottom: 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.06);">
                <div style="font-family: monospace; font-size: 0.85rem; color: var(--text-muted);">
                    Tur #@turn.TurnIndex · @turn.CreatedAtUtc.ToString("HH:mm:ss")
                </div>
                <div style="display: flex; gap: 0.6rem; align-items: center;">
                    <span style="background: rgba(0,0,0,0.3); border: 1px solid @KindBadgeColor(turn.Kind); color: @KindBadgeColor(turn.Kind); padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">
                        @turn.Kind
                    </span>
                    @if (turn.ShortCircuited)
                    {
                        <small style="color: var(--text-muted);">pre-flight</small>
                    }
                    <small style="color: var(--text-muted); font-family: monospace;">@turn.LatencyMs ms</small>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr; gap: 0.85rem;">
                <div>
                    <div style="color: var(--secondary); font-size: 0.85rem; margin-bottom: 0.3rem;"><i class="fa-solid fa-user"></i> Kullanıcı</div>
                    <div style="background: rgba(255,255,255,0.04); padding: 0.75rem 1rem; border-radius: 8px; white-space: pre-wrap; word-break: break-word;">@turn.UserMessage</div>
                </div>
                <div>
                    <div style="color: var(--primary); font-size: 0.85rem; margin-bottom: 0.3rem;"><i class="fa-solid fa-robot"></i> Bot @(string.IsNullOrEmpty(turn.ModelId) ? "" : $"({turn.ModelId})")</div>
                    <div style="background: rgba(109, 40, 217, 0.06); padding: 0.75rem 1rem; border-radius: 8px; white-space: pre-wrap; word-break: break-word;">
                        @(string.IsNullOrEmpty(turn.BotResponse) ? "—" : turn.BotResponse)
                    </div>
                </div>
            </div>
        </div>
    }
</div>
