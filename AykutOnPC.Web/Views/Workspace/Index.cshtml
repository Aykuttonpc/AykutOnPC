@{
    ViewData["Title"] = "My Workspace";
    Layout = "_AdminLayout";
}

<!-- SortableJS — drag/drop between columns and within a column -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>

<style>
    .kb-toolbar {
        display: flex; align-items: center; gap: 0.75rem;
        margin-bottom: 1.25rem; flex-wrap: wrap;
    }
    .kb-toolbar h1 {
        margin: 0; font-size: 1.55rem;
        background: linear-gradient(135deg, #c4b5fd, #06b6d4);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .kb-toolbar .grow { flex: 1; }
    .kb-input {
        padding: 0.5rem 0.75rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1);
        background: rgba(10,10,15,0.7); color: var(--text-main); font-family: inherit; font-size: 0.9rem;
        min-width: 220px;
    }
    .kb-btn {
        padding: 0.5rem 0.95rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04); color: var(--text-main); cursor: pointer;
        font-size: 0.85rem; transition: 0.15s; display: inline-flex; gap: 0.4rem; align-items: center;
    }
    .kb-btn:hover { background: rgba(255,255,255,0.08); border-color: rgba(109,40,217,0.5); }
    .kb-btn.primary { background: rgba(109,40,217,0.18); border-color: rgba(109,40,217,0.5); color: #c4b5fd; }
    .kb-btn.primary:hover { background: rgba(109,40,217,0.28); }
    .kb-btn.danger { color: #ef4444; border-color: rgba(239,68,68,0.25); }

    .kb-filter-chip {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.3rem 0.7rem; border-radius: 999px; font-size: 0.78rem; cursor: pointer;
        border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.03);
        color: var(--text-muted); user-select: none;
    }
    .kb-filter-chip.on { border-color: currentColor; background: var(--chip-bg, rgba(255,255,255,0.08)); }

    .kb-toggle { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--text-muted); font-size: 0.85rem; cursor: pointer; }
    .kb-toggle input { accent-color: #6d28d9; }

    /* ── Board (4 columns) ── */
    .kb-board {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;
        min-height: calc(100vh - 220px);
    }
    @@media (max-width: 1100px) { .kb-board { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 700px)  { .kb-board { grid-template-columns: 1fr; } }

    .kb-col {
        background: rgba(10,10,15,0.6); border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px; padding: 0.85rem; display: flex; flex-direction: column;
    }
    .kb-col-header {
        display: flex; align-items: center; justify-content: space-between;
        padding-bottom: 0.6rem; margin-bottom: 0.6rem;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .kb-col-header h3 { margin: 0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); }
    .kb-col-count { color: var(--text-muted); font-size: 0.78rem; font-family: monospace; }
    .kb-col-body { flex: 1; min-height: 80px; display: flex; flex-direction: column; gap: 0.5rem; }
    .kb-col-body.sortable-drag-over { background: rgba(109,40,217,0.06); border-radius: 6px; }

    .kb-add-card {
        background: none; border: 1px dashed rgba(255,255,255,0.12); border-radius: 8px;
        padding: 0.55rem; color: var(--text-muted); cursor: pointer; font-size: 0.82rem;
        margin-top: 0.4rem;
    }
    .kb-add-card:hover { color: white; border-color: rgba(109,40,217,0.5); }

    /* ── Cards ── */
    .pbi-card {
        background: rgba(20,20,28,0.95); border-radius: 10px; padding: 0.7rem 0.85rem;
        border-left: 4px solid #64748b; cursor: grab;
        transition: transform 0.12s, box-shadow 0.12s;
        position: relative;
    }
    .pbi-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.4); transform: translateY(-1px); }
    .pbi-card.sortable-ghost { opacity: 0.4; }
    .pbi-card.sortable-chosen { cursor: grabbing; }
    .pbi-card.p1 { border-left-color: #ef4444; }
    .pbi-card.p2 { border-left-color: #f59e0b; }
    .pbi-card.p3 { border-left-color: #64748b; }
    .pbi-card.overdue { background: rgba(239,68,68,0.05); }

    .pbi-card-title {
        font-size: 0.92rem; line-height: 1.35; margin: 0;
        word-break: break-word;
    }
    .pbi-card.done .pbi-card-title { text-decoration: line-through; color: var(--text-muted); }
    .pbi-card-desc {
        color: var(--text-muted); font-size: 0.78rem; margin: 0.35rem 0 0;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .pbi-card-meta {
        display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.5rem; align-items: center;
    }
    .pbi-label-chip {
        display: inline-flex; align-items: center; padding: 0.12rem 0.5rem;
        border-radius: 999px; font-size: 0.7rem; font-weight: 600;
        color: white; line-height: 1.4;
    }
    .pbi-card-due { font-size: 0.7rem; color: var(--text-muted); margin-left: auto; font-family: monospace; }
    .pbi-card-due.overdue { color: #ef4444; }

    .pbi-card-actions {
        position: absolute; top: 0.45rem; right: 0.5rem; display: flex; gap: 0.2rem; opacity: 0;
        transition: opacity 0.12s;
    }
    .pbi-card:hover .pbi-card-actions { opacity: 1; }
    .pbi-card-actions button {
        background: none; border: none; color: var(--text-muted); cursor: pointer;
        padding: 0.15rem 0.35rem; border-radius: 4px; font-size: 0.75rem;
    }
    .pbi-card-actions button:hover { color: white; background: rgba(255,255,255,0.08); }

    /* ── Modals ── */
    .kb-modal-backdrop {
        position: fixed; inset: 0; background: rgba(0,0,0,0.65); z-index: 999;
        display: none; align-items: center; justify-content: center;
    }
    .kb-modal-backdrop.open { display: flex; }
    .kb-modal {
        background: #0f0f17; border: 1px solid rgba(255,255,255,0.1); border-radius: 14px;
        padding: 1.5rem; min-width: 460px; max-width: 92vw; max-height: 90vh; overflow: auto;
    }
    .kb-modal h2 { margin: 0 0 1rem 0; font-size: 1.1rem; }
    .kb-modal label { display: block; color: var(--text-muted); font-size: 0.8rem; margin: 0.85rem 0 0.3rem; }
    .kb-modal input, .kb-modal select, .kb-modal textarea {
        width: 100%; padding: 0.55rem 0.7rem; background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; color: white;
        font-family: inherit; font-size: 0.9rem;
    }
    .kb-modal textarea { resize: vertical; min-height: 90px; }
    .kb-modal .modal-actions { display: flex; gap: 0.6rem; justify-content: flex-end; margin-top: 1.25rem; }

    .label-picker {
        display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.3rem;
    }
    .label-picker .picker-chip {
        cursor: pointer; opacity: 0.5; transition: opacity 0.12s;
    }
    .label-picker .picker-chip.on { opacity: 1; }

    .label-row {
        display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .label-row:last-child { border-bottom: none; }
    .label-row .swatch {
        width: 18px; height: 18px; border-radius: 4px; flex-shrink: 0;
    }
    .label-row input[type=text]  { flex: 1; padding: 0.35rem 0.5rem; }
    .label-row input[type=color] { width: 40px; height: 32px; padding: 0; border: none; background: none; cursor: pointer; }
    .label-row .del { background: none; border: none; color: #ef4444; cursor: pointer; }
</style>

<div class="kb-toolbar">
    <h1><i class="fa-solid fa-table-list" style="color:#c4b5fd; margin-right:0.5rem;"></i>My Workspace</h1>
    <input id="kbSearch" class="kb-input" type="text" placeholder="Ara... (başlık + açıklama)">
    <label class="kb-toggle"><input type="checkbox" id="kbHideDone"> Done gizle</label>
    <div id="kbPriorityChips" style="display:flex; gap:0.35rem;">
        <span class="kb-filter-chip" data-pri="1" style="--chip-bg:rgba(239,68,68,0.18); color:#fca5a5;">P1</span>
        <span class="kb-filter-chip" data-pri="2" style="--chip-bg:rgba(245,158,11,0.18); color:#fcd34d;">P2</span>
        <span class="kb-filter-chip" data-pri="3" style="--chip-bg:rgba(100,116,139,0.18); color:#cbd5e1;">P3</span>
    </div>
    <div class="grow"></div>
    <button id="kbManageLabelsBtn" class="kb-btn"><i class="fa-solid fa-tags"></i> Etiketler</button>
    <button id="kbNewPbiBtn" class="kb-btn primary"><i class="fa-solid fa-plus"></i> Yeni Kart</button>
</div>

<div id="kbLabelFilter" style="display:flex; flex-wrap:wrap; gap:0.35rem; margin-bottom:1rem;"></div>

<div class="kb-board">
    <div class="kb-col" data-state="Backlog">
        <div class="kb-col-header"><h3>📥 Backlog</h3><span class="kb-col-count">0</span></div>
        <div class="kb-col-body" data-col-body></div>
        <button class="kb-add-card" data-quick-add="Backlog">+ Hızlı ekle</button>
    </div>
    <div class="kb-col" data-state="Todo">
        <div class="kb-col-header"><h3>📝 To Do</h3><span class="kb-col-count">0</span></div>
        <div class="kb-col-body" data-col-body></div>
        <button class="kb-add-card" data-quick-add="Todo">+ Hızlı ekle</button>
    </div>
    <div class="kb-col" data-state="Doing">
        <div class="kb-col-header"><h3>⚙️ Doing</h3><span class="kb-col-count">0</span></div>
        <div class="kb-col-body" data-col-body></div>
        <button class="kb-add-card" data-quick-add="Doing">+ Hızlı ekle</button>
    </div>
    <div class="kb-col" data-state="Done">
        <div class="kb-col-header"><h3>✅ Done</h3><span class="kb-col-count">0</span></div>
        <div class="kb-col-body" data-col-body></div>
        <button class="kb-add-card" data-quick-add="Done">+ Hızlı ekle</button>
    </div>
</div>

<!-- ── PBI modal (yeni + düzenle) ─────────────────────────────── -->
<div id="pbiModal" class="kb-modal-backdrop">
    <div class="kb-modal">
        <h2 id="pbiModalTitle">Yeni Kart</h2>
        <input type="hidden" id="pbiId">
        <label>Başlık</label>
        <input type="text" id="pbiTitle" placeholder="örn. Login redirect bug'ı düzelt" maxlength="300">
        <label>Açıklama</label>
        <textarea id="pbiDescription" placeholder="Detaylar, acceptance criteria..." maxlength="8000"></textarea>
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.6rem;">
            <div>
                <label>Kolon</label>
                <select id="pbiState">
                    <option value="Backlog">📥 Backlog</option>
                    <option value="Todo">📝 To Do</option>
                    <option value="Doing">⚙️ Doing</option>
                    <option value="Done">✅ Done</option>
                </select>
            </div>
            <div>
                <label>Öncelik</label>
                <select id="pbiPriority">
                    <option value="1">P1 — acil</option>
                    <option value="2" selected>P2 — normal</option>
                    <option value="3">P3 — sonra</option>
                </select>
            </div>
            <div>
                <label>Tarih (opsiyonel)</label>
                <input type="date" id="pbiDueDate">
            </div>
        </div>
        <label>Etiketler</label>
        <div class="label-picker" id="pbiLabelPicker"></div>
        <div class="modal-actions">
            <button class="kb-btn danger" id="pbiDeleteBtn" style="display:none;"><i class="fa-solid fa-trash"></i> Sil</button>
            <div style="flex:1"></div>
            <button class="kb-btn" data-action="cancel">Vazgeç</button>
            <button class="kb-btn primary" id="pbiSaveBtn">Kaydet</button>
        </div>
    </div>
</div>

<!-- ── Etiketler yönetim modal ─────────────────────────────── -->
<div id="labelsModal" class="kb-modal-backdrop">
    <div class="kb-modal">
        <h2><i class="fa-solid fa-tags"></i> Etiketleri Yönet</h2>
        <div id="labelsList" style="margin-top:0.5rem;"></div>
        <div style="margin-top:1rem; border-top:1px solid rgba(255,255,255,0.05); padding-top:1rem;">
            <label>Yeni etiket</label>
            <div class="label-row" style="border:none; padding:0;">
                <input type="color" id="newLabelColor" value="#3b82f6">
                <input type="text" id="newLabelName" placeholder="İsim (örn. Backend)" maxlength="40">
                <button class="kb-btn primary" id="addLabelBtn">Ekle</button>
            </div>
        </div>
        <div class="modal-actions">
            <button class="kb-btn" data-action="cancel">Kapat</button>
        </div>
    </div>
</div>

<script>
    // ── Application state ──────────────────────────────────────────
    let pbis = [];
    let labels = [];
    const sortables = []; // per-column Sortable instances
    const filter = {
        search: '',
        labelIds: new Set(),
        priorities: new Set(),
        hideDone: false
    };

    document.addEventListener('DOMContentLoaded', async () => {
        wireToolbar();
        wireModals();
        await refresh();
    });

    async function refresh() {
        const snap = await fetch('/api/workspace/snapshot').then(r => r.ok ? r.json() : null);
        if (!snap) return;
        pbis = snap.pbis || [];
        labels = snap.labels || [];
        renderLabelFilter();
        renderBoard();
    }

    // ── Toolbar wiring ─────────────────────────────────────────────
    function wireToolbar() {
        document.getElementById('kbSearch').addEventListener('input', (e) => {
            filter.search = e.target.value.toLowerCase().trim();
            renderBoard();
        });
        document.getElementById('kbHideDone').addEventListener('change', (e) => {
            filter.hideDone = e.target.checked;
            renderBoard();
        });
        document.querySelectorAll('#kbPriorityChips .kb-filter-chip').forEach(chip => {
            chip.addEventListener('click', () => {
                const p = parseInt(chip.dataset.pri, 10);
                if (filter.priorities.has(p)) filter.priorities.delete(p);
                else filter.priorities.add(p);
                chip.classList.toggle('on');
                renderBoard();
            });
        });
        document.getElementById('kbNewPbiBtn').addEventListener('click', () => openPbiModal(null));
        document.getElementById('kbManageLabelsBtn').addEventListener('click', () => openLabelsModal());

        // Quick-add buttons (one per column) — minimal: prompt for title, defaults to that column
        document.querySelectorAll('[data-quick-add]').forEach(btn => {
            btn.addEventListener('click', async () => {
                const state = btn.dataset.quickAdd;
                const title = prompt(`${state} — yeni kart başlığı:`);
                if (!title || !title.trim()) return;
                await api('POST', '/api/workspace/pbis', { title: title.trim(), state, priority: 2 });
                await refresh();
            });
        });
    }

    function wireModals() {
        document.querySelectorAll('.kb-modal-backdrop').forEach(bd => {
            bd.addEventListener('click', (e) => { if (e.target === bd) closeAllModals(); });
            bd.querySelectorAll('[data-action="cancel"]').forEach(b => b.addEventListener('click', closeAllModals));
        });
        document.getElementById('pbiSaveBtn').addEventListener('click', submitPbi);
        document.getElementById('pbiDeleteBtn').addEventListener('click', deletePbi);
        document.getElementById('addLabelBtn').addEventListener('click', submitNewLabel);
    }

    // ── Render: label filter row ───────────────────────────────────
    function renderLabelFilter() {
        const wrap = document.getElementById('kbLabelFilter');
        wrap.innerHTML = '';
        for (const l of labels) {
            const chip = document.createElement('span');
            chip.className = 'kb-filter-chip' + (filter.labelIds.has(l.id) ? ' on' : '');
            chip.style.setProperty('--chip-bg', hexA(l.color, 0.22));
            chip.style.color = l.color;
            chip.textContent = l.name;
            chip.addEventListener('click', () => {
                if (filter.labelIds.has(l.id)) filter.labelIds.delete(l.id);
                else filter.labelIds.add(l.id);
                renderLabelFilter();
                renderBoard();
            });
            wrap.appendChild(chip);
        }
    }

    // ── Render: board (4 columns) ──────────────────────────────────
    function renderBoard() {
        const visible = pbis.filter(matchesFilter);
        const byState = { Backlog: [], Todo: [], Doing: [], Done: [] };
        for (const p of visible) (byState[p.state] || (byState[p.state] = [])).push(p);

        // Sort each column by sortOrder (server already returns sorted, but filter may interleave)
        for (const k of Object.keys(byState)) byState[k].sort((a, b) => a.sortOrder - b.sortOrder);

        document.querySelectorAll('.kb-col').forEach(col => {
            const state = col.dataset.state;
            const body  = col.querySelector('[data-col-body]');
            const list  = byState[state] || [];
            col.querySelector('.kb-col-count').textContent = list.length;
            body.innerHTML = '';
            for (const p of list) body.appendChild(renderCard(p));
        });

        wireSortables();
    }

    function matchesFilter(p) {
        if (filter.hideDone && p.state === 'Done') return false;
        if (filter.priorities.size && !filter.priorities.has(p.priority)) return false;
        if (filter.labelIds.size) {
            // Card must carry ALL selected labels (AND semantics — usually what you want for a tag filter)
            for (const lid of filter.labelIds) if (!p.labelIds.includes(lid)) return false;
        }
        if (filter.search) {
            const hay = (p.title + ' ' + (p.description || '')).toLowerCase();
            if (!hay.includes(filter.search)) return false;
        }
        return true;
    }

    function renderCard(p) {
        const card = document.createElement('div');
        card.className = `pbi-card p${p.priority}` + (p.state === 'Done' ? ' done' : '');
        card.dataset.id = p.id;

        const due = p.dueDateUtc ? new Date(p.dueDateUtc) : null;
        const today = new Date(); today.setHours(0,0,0,0);
        const overdue = due && due < today && p.state !== 'Done';
        if (overdue) card.classList.add('overdue');

        const labelChips = p.labelIds
            .map(id => labels.find(l => l.id === id))
            .filter(Boolean)
            .map(l => `<span class="pbi-label-chip" style="background:${l.color}">${escapeHtml(l.name)}</span>`)
            .join('');

        card.innerHTML = `
            <div class="pbi-card-actions">
                <button data-act="edit" title="Düzenle"><i class="fa-solid fa-pen"></i></button>
            </div>
            <p class="pbi-card-title">${escapeHtml(p.title)}</p>
            ${p.description ? `<p class="pbi-card-desc">${escapeHtml(p.description)}</p>` : ''}
            ${(labelChips || due) ? `
                <div class="pbi-card-meta">
                    ${labelChips}
                    ${due ? `<span class="pbi-card-due ${overdue ? 'overdue' : ''}">${due.toISOString().slice(0,10)}</span>` : ''}
                </div>` : ''}
        `;
        card.querySelector('[data-act="edit"]').addEventListener('click', (e) => {
            e.stopPropagation();
            openPbiModal(p);
        });
        // Double-click anywhere on the card → edit (matches Trello/Azure muscle memory)
        card.addEventListener('dblclick', () => openPbiModal(p));
        return card;
    }

    // ── SortableJS wiring ──────────────────────────────────────────
    function wireSortables() {
        // Tear down old instances first — we rebuild on every render to keep things simple
        // and to make sure the new DOM references are bound.
        for (const s of sortables) s.destroy();
        sortables.length = 0;

        document.querySelectorAll('[data-col-body]').forEach(body => {
            const s = Sortable.create(body, {
                group: 'pbi',
                animation: 140,
                ghostClass: 'sortable-ghost',
                chosenClass: 'sortable-chosen',
                onEnd: async (evt) => {
                    const id = parseInt(evt.item.dataset.id, 10);
                    const newState = evt.to.closest('.kb-col').dataset.state;
                    const newIndex = evt.newIndex;
                    // Optimistic: card is already in the new DOM position. Fire server move,
                    // then re-fetch the snapshot to pick up server-side renumbering. If the
                    // server rejects, the refresh will snap it back to the truth.
                    await api('PATCH', `/api/workspace/pbis/${id}/move`, { state: newState, sortOrder: newIndex });
                    await refresh();
                }
            });
            sortables.push(s);
        });
    }

    // ── PBI modal ──────────────────────────────────────────────────
    function openPbiModal(pbi) {
        const isEdit = !!pbi;
        document.getElementById('pbiModalTitle').textContent = isEdit ? 'Kartı Düzenle' : 'Yeni Kart';
        document.getElementById('pbiId').value           = isEdit ? pbi.id : '';
        document.getElementById('pbiTitle').value        = isEdit ? pbi.title : '';
        document.getElementById('pbiDescription').value  = isEdit ? (pbi.description || '') : '';
        document.getElementById('pbiState').value        = isEdit ? pbi.state : 'Backlog';
        document.getElementById('pbiPriority').value     = isEdit ? pbi.priority : 2;
        document.getElementById('pbiDueDate').value      = isEdit && pbi.dueDateUtc ? pbi.dueDateUtc.slice(0,10) : '';
        document.getElementById('pbiDeleteBtn').style.display = isEdit ? 'inline-flex' : 'none';

        // Label picker chips — clickable, multi-select
        const picker = document.getElementById('pbiLabelPicker');
        picker.innerHTML = '';
        const selectedSet = new Set(isEdit ? pbi.labelIds : []);
        for (const l of labels) {
            const chip = document.createElement('span');
            chip.className = 'pbi-label-chip picker-chip' + (selectedSet.has(l.id) ? ' on' : '');
            chip.style.background = l.color;
            chip.dataset.id = l.id;
            chip.textContent = l.name;
            chip.addEventListener('click', () => {
                const id = parseInt(chip.dataset.id, 10);
                if (selectedSet.has(id)) { selectedSet.delete(id); chip.classList.remove('on'); }
                else                     { selectedSet.add(id);   chip.classList.add('on'); }
            });
            picker.appendChild(chip);
        }
        // Stash on the modal element for submit access — DOM is the truth, no shadow state needed
        document.getElementById('pbiModal').dataset.selected = JSON.stringify(Array.from(selectedSet));

        // Refresh on every click so we read the latest selection
        picker.addEventListener('click', () => {
            const on = Array.from(picker.querySelectorAll('.picker-chip.on')).map(c => parseInt(c.dataset.id, 10));
            document.getElementById('pbiModal').dataset.selected = JSON.stringify(on);
        });

        closeAllModals();
        document.getElementById('pbiModal').classList.add('open');
        setTimeout(() => document.getElementById('pbiTitle').focus(), 50);
    }

    async function submitPbi() {
        const id      = document.getElementById('pbiId').value;
        const title   = document.getElementById('pbiTitle').value.trim();
        if (!title) { alert('Başlık zorunlu.'); return; }
        const body = {
            title,
            description: document.getElementById('pbiDescription').value,
            state: document.getElementById('pbiState').value,
            priority: parseInt(document.getElementById('pbiPriority').value, 10),
            dueDateUtc: dateLocalToIso(document.getElementById('pbiDueDate').value),
            labelIds: JSON.parse(document.getElementById('pbiModal').dataset.selected || '[]')
        };
        if (id) {
            // Edit doesn't take "state" (move endpoint owns that). PATCH only the editable fields.
            const patch = { ...body }; delete patch.state;
            await api('PATCH', `/api/workspace/pbis/${id}`, patch);
            // If state changed in the modal, do a separate move call so column logic stays in one place
            const original = pbis.find(p => p.id === parseInt(id, 10));
            if (original && original.state !== body.state) {
                await api('PATCH', `/api/workspace/pbis/${id}/move`, { state: body.state, sortOrder: 9999 });
            }
        } else {
            await api('POST', '/api/workspace/pbis', body);
        }
        closeAllModals();
        await refresh();
    }

    async function deletePbi() {
        const id = document.getElementById('pbiId').value;
        if (!id) return;
        if (!confirm('Bu kart silinsin mi?')) return;
        await api('DELETE', `/api/workspace/pbis/${id}`);
        closeAllModals();
        await refresh();
    }

    // ── Labels modal ───────────────────────────────────────────────
    function openLabelsModal() {
        renderLabelsList();
        closeAllModals();
        document.getElementById('labelsModal').classList.add('open');
    }

    function renderLabelsList() {
        const wrap = document.getElementById('labelsList');
        wrap.innerHTML = '';
        if (labels.length === 0) {
            wrap.innerHTML = '<div style="color:var(--text-muted); padding:0.5rem 0;">Henüz etiket yok. Aşağıdan ekleyebilirsin.</div>';
            return;
        }
        for (const l of labels) {
            const row = document.createElement('div');
            row.className = 'label-row';
            row.innerHTML = `
                <input type="color" value="${l.color}" data-id="${l.id}" data-field="color">
                <input type="text"  value="${escapeAttr(l.name)}" data-id="${l.id}" data-field="name" maxlength="40">
                <button class="del" data-id="${l.id}"><i class="fa-solid fa-trash"></i></button>
            `;
            const debouncedSave = debounce(async () => {
                const color = row.querySelector('[data-field=color]').value;
                const name  = row.querySelector('[data-field=name]').value.trim();
                if (!name) return;
                await api('PATCH', `/api/workspace/labels/${l.id}`, { name, color });
                await refresh();
            }, 500);
            row.querySelectorAll('input').forEach(i => i.addEventListener('change', debouncedSave));
            row.querySelector('.del').addEventListener('click', async () => {
                if (!confirm(`"${l.name}" etiketi silinsin mi? Kartlardan kaldırılır.`)) return;
                await api('DELETE', `/api/workspace/labels/${l.id}`);
                await refresh();
                renderLabelsList();
            });
            wrap.appendChild(row);
        }
    }

    async function submitNewLabel() {
        const name  = document.getElementById('newLabelName').value.trim();
        const color = document.getElementById('newLabelColor').value;
        if (!name) { alert('İsim zorunlu.'); return; }
        const res = await fetch('/api/workspace/labels', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, color })
        });
        if (res.status === 409) {
            alert('Bu isimde bir etiket zaten var.');
            return;
        }
        document.getElementById('newLabelName').value = '';
        await refresh();
        renderLabelsList();
    }

    // ── Utils ──────────────────────────────────────────────────────
    function closeAllModals() {
        document.querySelectorAll('.kb-modal-backdrop').forEach(b => b.classList.remove('open'));
    }
    async function api(method, url, body) {
        const opts = { method, headers: { 'Content-Type': 'application/json' } };
        if (body !== undefined) opts.body = JSON.stringify(body);
        const res = await fetch(url, opts);
        if (!res.ok) { console.error(method, url, res.status); return null; }
        if (res.status === 204) return true;
        const ct = res.headers.get('content-type') || '';
        return ct.includes('application/json') ? await res.json() : true;
    }
    function escapeHtml(s) { const d = document.createElement('div'); d.textContent = s ?? ''; return d.innerHTML; }
    function escapeAttr(s) { return String(s ?? '').replace(/"/g, '&quot;'); }
    function dateLocalToIso(v) { return v ? new Date(v + 'T00:00:00Z').toISOString() : null; }
    function hexA(hex, alpha) {
        const r = parseInt(hex.slice(1,3), 16), g = parseInt(hex.slice(3,5), 16), b = parseInt(hex.slice(5,7), 16);
        return `rgba(${r},${g},${b},${alpha})`;
    }
    function debounce(fn, ms) { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); }; }
</script>
