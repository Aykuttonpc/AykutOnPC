@model AykutOnPC.Core.Entities.Profile
@{
    ViewData["Title"] = "Manage Profile";
    Layout = "_AdminLayout";
}

<h1 style="margin-bottom: 2rem;">Manage About Me & Social Media</h1>

@if (TempData["Success"] != null)
{
    <div style="background: rgba(34, 197, 94, 0.1); border: 1px solid #22c55e; color: #22c55e; padding: 1rem; border-radius: 8px; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.5rem;">
        <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
    </div>
}

<div class="card" style="max-width: 800px; height: auto; max-height: none; overflow: visible;">
    <form asp-controller="Profile" asp-action="Update" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" style="color: #ef4444; margin-bottom: 1rem;"></div>
        
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Full Name</label>
                    <input asp-for="FullName" class="form-control" />
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Title / Headline</label>
                    <input asp-for="Title" class="form-control" placeholder="Full Stack Developer & AI Enthusiast" />
                </div>
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Bio / About Me</label>
                <textarea asp-for="Bio" class="form-control" rows="5" placeholder="Tell the world about yourself..."></textarea>
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Profile Picture URL</label>
                <input asp-for="ProfilePictureUrl" class="form-control" placeholder="https://..." />
            </div>

            <h3 style="margin-top: 1rem; color: var(--secondary);">Social Media Links</h3>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">GitHub URL</label>
                    <input asp-for="GitHubUrl" class="form-control" placeholder="https://github.com/..." />
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">LinkedIn URL</label>
                    <input asp-for="LinkedInUrl" class="form-control" placeholder="https://linkedin.com/in/..." />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Twitter / X URL</label>
                    <input asp-for="TwitterUrl" class="form-control" placeholder="https://x.com/..." />
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Instagram URL</label>
                    <input asp-for="InstagramUrl" class="form-control" placeholder="https://instagram.com/..." />
                </div>
            </div>

            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Public Email</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="hello@example.com" />
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-save"></i> Save Profile Changes
                </button>
            </div>
        </div>
    </form>
</div>

<style>
    .form-control {
        width: 100%;
        padding: 0.75rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        color: white;
        font-family: inherit;
    }
    .form-control:focus {
        outline: none;
        border-color: var(--primary);
    }
</style>
